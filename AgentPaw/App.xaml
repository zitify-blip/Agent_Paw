<Application x:Class="AgentPaw.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:AgentPaw.Helpers"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisConverter" />
            <helpers:NullToCollapsedConverter x:Key="NullToCollapsedConverter" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />
            <helpers:ZeroToVisibleConverter x:Key="ZeroToVisibleConverter" />
            <helpers:RoleToVisibilityConverter x:Key="RoleToVisConverter" />
            <helpers:ForcePersonaTextConverter x:Key="ForcePersonaTextConverter" />
            <helpers:BoolToToggleTextConverter x:Key="BoolToToggleTextConverter" />
            <helpers:AvatarToImageConverter x:Key="AvatarToImageConverter" />
            <helpers:EmptyToVisibleConverter x:Key="EmptyToVisibleConverter" />
            <helpers:NotEmptyToVisibleConverter x:Key="NotEmptyToVisibleConverter" />
            <helpers:IconNameToSymbolConverter x:Key="IconNameToSymbolConverter" />
            <helpers:PersonaColorToBrushConverter x:Key="PersonaColorToBrushConverter" />
            <helpers:EqualityMultiConverter x:Key="EqualityMultiConverter" />

            <!-- ═══════════════════════════════════════════════════════
                 Agent Paw Design System
                 "Warm Analog Sketchbook" — 디자인 시안 충실 반영
                 ═══════════════════════════════════════════════════════ -->

            <!-- ─── Core Tones ─── -->
            <Color x:Key="PawParchmentColor">#F5F0E8</Color>
            <Color x:Key="PawCreamColor">#EDE8DC</Color>
            <Color x:Key="PawCardColor">#FAF7F2</Color>
            <Color x:Key="PawSidebarBrownColor">#3A2F28</Color>
            <Color x:Key="PawSidebarHoverColor">#4A3F35</Color>
            <Color x:Key="PawSidebarBorderColor">#5C4A3A</Color>
            <Color x:Key="PawSidebarTextColor">#D4C4A8</Color>
            <Color x:Key="PawSidebarMutedColor">#9C8B78</Color>
            <Color x:Key="PawSidebarHeadingColor">#EDE8DC</Color>
            <Color x:Key="PawSidebarVersionColor">#6B5E50</Color>
            <Color x:Key="PawGoldColor">#C8A96E</Color>
            <Color x:Key="PawBorderColor">#D4C4A8</Color>
            <Color x:Key="PawArchiveBgColor">#F0EBE2</Color>
            <Color x:Key="PawArchiveTextColor">#8B7355</Color>
            <Color x:Key="PawArchiveSubTextColor">#A09080</Color>
            <Color x:Key="PawTextPrimaryColor">#2D2A26</Color>
            <Color x:Key="PawTextSecondaryColor">#6B6560</Color>

            <!-- ─── Semantic Colors ─── -->
            <Color x:Key="PawPlanningBlueColor">#4A7FB5</Color>
            <Color x:Key="PawImplOrangeColor">#C97B3E</Color>
            <Color x:Key="PawArchYellowColor">#C9A93E</Color>
            <Color x:Key="PawSystemGreenColor">#6B9B4A</Color>
            <Color x:Key="PawErrorRedColor">#B85450</Color>

            <!-- ─── Solid Brushes ─── -->
            <SolidColorBrush x:Key="PawGold" Color="{StaticResource PawGoldColor}" />
            <SolidColorBrush x:Key="PawDarkBg" Color="{StaticResource PawParchmentColor}" />
            <SolidColorBrush x:Key="PawSidebarBg" Color="{StaticResource PawSidebarBrownColor}" />
            <SolidColorBrush x:Key="PawAccent" Color="{StaticResource PawCreamColor}" />
            <SolidColorBrush x:Key="PawCardBg" Color="{StaticResource PawCardColor}" />
            <SolidColorBrush x:Key="PawBorder" Color="{StaticResource PawBorderColor}" />
            <SolidColorBrush x:Key="PawTextPrimary" Color="{StaticResource PawTextPrimaryColor}" />
            <SolidColorBrush x:Key="PawTextSecondary" Color="{StaticResource PawTextSecondaryColor}" />
            <SolidColorBrush x:Key="PawPlanningBlue" Color="{StaticResource PawPlanningBlueColor}" />
            <SolidColorBrush x:Key="PawImplOrange" Color="{StaticResource PawImplOrangeColor}" />
            <SolidColorBrush x:Key="PawArchYellow" Color="{StaticResource PawArchYellowColor}" />
            <SolidColorBrush x:Key="PawSystemGreen" Color="{StaticResource PawSystemGreenColor}" />
            <SolidColorBrush x:Key="PawErrorRed" Color="{StaticResource PawErrorRedColor}" />
            <SolidColorBrush x:Key="PawCreamBrush" Color="{StaticResource PawCreamColor}" />
            <SolidColorBrush x:Key="PawSidebarBorder" Color="{StaticResource PawSidebarBorderColor}" />
            <SolidColorBrush x:Key="PawSidebarText" Color="{StaticResource PawSidebarTextColor}" />
            <SolidColorBrush x:Key="PawSidebarMuted" Color="{StaticResource PawSidebarMutedColor}" />
            <SolidColorBrush x:Key="PawSidebarHeading" Color="{StaticResource PawSidebarHeadingColor}" />
            <SolidColorBrush x:Key="PawSidebarVersion" Color="{StaticResource PawSidebarVersionColor}" />
            <SolidColorBrush x:Key="PawArchiveBg" Color="{StaticResource PawArchiveBgColor}" />
            <SolidColorBrush x:Key="PawArchiveText" Color="{StaticResource PawArchiveTextColor}" />
            <SolidColorBrush x:Key="PawArchiveSubText" Color="{StaticResource PawArchiveSubTextColor}" />
            <SolidColorBrush x:Key="PawGoldTint" Color="{StaticResource PawGoldColor}" Opacity="0.13" />
            <SolidColorBrush x:Key="PawStatusDotIdle" Color="{StaticResource PawArchiveSubTextColor}" />

            <!-- ─── Typography ─── -->
            <FontFamily x:Key="PawFont">Pretendard, Malgun Gothic, Segoe UI</FontFamily>

            <!-- ═══════════════════════════════════════════════════════
                 Paper Texture System
                 시안의 핵심: 밋밋한 flat 배경이 아닌 종이 질감
                 ═══════════════════════════════════════════════════════ -->

            <!-- Paw Print Geometry (main pad + 4 toes) -->
            <GeometryGroup x:Key="PawPrintGeometry" FillRule="Nonzero">
                <EllipseGeometry Center="10,14" RadiusX="6" RadiusY="5" />
                <EllipseGeometry Center="3,5" RadiusX="2.5" RadiusY="2.8" />
                <EllipseGeometry Center="8,2.5" RadiusX="2.2" RadiusY="2.8" />
                <EllipseGeometry Center="13,2.5" RadiusX="2.2" RadiusY="2.8" />
                <EllipseGeometry Center="18,5" RadiusX="2.5" RadiusY="2.8" />
            </GeometryGroup>

            <!-- Paper grain noise texture (종이 섬유 질감) -->
            <DrawingBrush x:Key="PaperGrainBrush"
                          TileMode="Tile" Stretch="None"
                          Viewport="0,0,60,60" ViewportUnits="Absolute"
                          Opacity="0.035">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#8B7355">
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <RectangleGeometry Rect="3,2,2,0.6" />
                                    <RectangleGeometry Rect="12,8,1.5,0.5" />
                                    <RectangleGeometry Rect="25,3,1.8,0.4" />
                                    <RectangleGeometry Rect="38,6,1.2,0.7" />
                                    <RectangleGeometry Rect="50,1,1.6,0.5" />
                                    <RectangleGeometry Rect="7,18,1.4,0.6" />
                                    <RectangleGeometry Rect="20,15,2,0.4" />
                                    <RectangleGeometry Rect="33,20,1,0.8" />
                                    <RectangleGeometry Rect="45,17,1.8,0.5" />
                                    <RectangleGeometry Rect="55,22,1.3,0.6" />
                                    <RectangleGeometry Rect="2,32,1.6,0.5" />
                                    <RectangleGeometry Rect="15,28,1.2,0.7" />
                                    <RectangleGeometry Rect="28,35,1.8,0.4" />
                                    <RectangleGeometry Rect="42,30,1.4,0.6" />
                                    <RectangleGeometry Rect="53,34,2,0.5" />
                                    <RectangleGeometry Rect="8,45,1.5,0.6" />
                                    <RectangleGeometry Rect="22,42,1,0.8" />
                                    <RectangleGeometry Rect="35,48,1.6,0.4" />
                                    <RectangleGeometry Rect="48,44,1.3,0.7" />
                                    <RectangleGeometry Rect="56,50,1.8,0.5" />
                                    <EllipseGeometry Center="10,12" RadiusX="0.6" RadiusY="0.6" />
                                    <EllipseGeometry Center="30,8" RadiusX="0.5" RadiusY="0.5" />
                                    <EllipseGeometry Center="48,25" RadiusX="0.7" RadiusY="0.7" />
                                    <EllipseGeometry Center="18,40" RadiusX="0.5" RadiusY="0.5" />
                                    <EllipseGeometry Center="40,52" RadiusX="0.6" RadiusY="0.6" />
                                    <EllipseGeometry Center="55,10" RadiusX="0.4" RadiusY="0.4" />
                                    <EllipseGeometry Center="5,55" RadiusX="0.5" RadiusY="0.5" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- Content area paw print tiles -->
            <DrawingBrush x:Key="PawPrintTileBrush"
                          TileMode="Tile" Stretch="None"
                          Viewport="0,0,160,170" ViewportUnits="Absolute"
                          Opacity="0.025">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="2" ScaleY="2" />
                                <RotateTransform Angle="-12" CenterX="40" CenterY="40" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Brush="#8B7355" Geometry="{StaticResource PawPrintGeometry}" />
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- Sidebar paw print brush -->
            <DrawingBrush x:Key="PawPrintSidebarBrush"
                          TileMode="Tile" Stretch="None"
                          Viewport="0,0,120,130" ViewportUnits="Absolute"
                          Opacity="0.05">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="2.2" ScaleY="2.2" />
                                <RotateTransform Angle="-15" CenterX="10" CenterY="10" />
                                <TranslateTransform X="25" Y="30" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Brush="#D4C4A8" Geometry="{StaticResource PawPrintGeometry}" />
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- Login page paw pattern -->
            <DrawingBrush x:Key="PawPrintLoginBrush"
                          TileMode="Tile" Stretch="None"
                          Viewport="0,0,180,190" ViewportUnits="Absolute"
                          Opacity="0.035">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="2.8" ScaleY="2.8" />
                                <RotateTransform Angle="20" CenterX="10" CenterY="10" />
                                <TranslateTransform X="40" Y="45" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Brush="#C8A96E" Geometry="{StaticResource PawPrintGeometry}" />
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <!-- ═══════════════════════════════════════════════════════
                 Card Styles — 시안의 "종이 위에 올려놓은 카드" 느낌
                 ═══════════════════════════════════════════════════════ -->

            <!-- Main card style (warm paper note on parchment) -->
            <Style x:Key="PawCardStyle" TargetType="Border">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FDFBF8" Offset="0" />
                            <GradientStop Color="#FAF7F2" Offset="0.4" />
                            <GradientStop Color="#F7F3EC" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#DDD0B8" Offset="0" />
                            <GradientStop Color="#C8B898" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="20,16" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="16" Opacity="0.12"
                                          ShadowDepth="3" Direction="260"
                                          Color="#7A6545" />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
