<UserControl x:Class="AgentPaw.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Loaded="SettingsPage_Loaded">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                           VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="환경 설정"
                           FontSize="24" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}" />
            </StackPanel>

            <!-- Messages -->
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=SuccessText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.1" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource PawSystemGreen}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="SuccessText"
                               Foreground="{DynamicResource PawSystemGreen}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Google Chat Bot -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Google Chat 봇" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="BotToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleBot_Click" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="BotStatusDot" Width="8" Height="8" Fill="{DynamicResource PawStatusDotIdle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="BotStatusText" Text="중지됨" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>

                    <TextBlock Text="GCP Project ID" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="GcpProjectInput" PlaceholderText="my-project-id"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <TextBlock Text="Pub/Sub Topic" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="TopicInput" PlaceholderText="projects/xxx/topics/xxx"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <TextBlock Text="Pub/Sub Subscription" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="SubscriptionInput" PlaceholderText="projects/xxx/subscriptions/xxx"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="서비스 계정" FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="ServiceAccountStatus" Text="미설정" FontSize="11"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:Button Content="JSON 업로드" Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}" Padding="8,4"
                                       Click="UploadServiceAccount_Click" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="PubSub 재시작" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="RestartPubSub_Click" />
                        <ui:Button Content="설정 저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="SaveBotConfig_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- WebSocket Server -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="WebSocket 서버" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <TextBlock x:Name="WsStatusText" Text="포트 8765" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ui:Button x:Name="WsToggleButton" Content="시작"
                               DockPanel.Dock="Right" Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Click="ToggleWebSocket_Click" />
                </DockPanel>
            </Border>

            <!-- Google Chat Spaces -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Google Chat 스페이스" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="새로고침" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Click="RefreshSpaces_Click" />
                    </DockPanel>

                    <ItemsControl x:Name="SpaceLinksPanel">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                                        <TextBlock Text="{Binding SpaceName}" FontSize="11"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="{Binding Enabled, Converter={StaticResource BoolToToggleTextConverter}}"
                                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4" Margin="0,0,4,0"
                                                   Click="ToggleSpace_Click" Tag="{Binding}" />
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                   Padding="4" ToolTip="스페이스 삭제"
                                                   Click="DeleteSpace_Click" Tag="{Binding}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoSpacesText" Text="등록된 스페이스가 없다."
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Slack Bot -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Slack 봇" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="SlackBotToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleSlackBot_Click" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="SlackBotStatusDot" Width="8" Height="8" Fill="{DynamicResource PawStatusDotIdle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="SlackBotStatusText" Text="비활성" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>

                    <!-- Bot Token -->
                    <TextBlock Text="봇 토큰 (xoxb-...)" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel x:Name="SlackBotTokenInputPanel" Orientation="Horizontal">
                            <PasswordBox x:Name="SlackBotTokenInput" Width="320"
                                         FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                            <ui:Button Content="저장" Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                       Click="SaveSlackBotToken_Click" />
                        </StackPanel>
                        <StackPanel x:Name="SlackBotTokenSetPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock x:Name="SlackBotTokenStatus" Text="xoxb-••••••••" FontSize="13"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <ui:Button Content="삭제" Appearance="Danger"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" FontSize="11"
                                       Click="DeleteSlackBotToken_Click" />
                        </StackPanel>
                    </DockPanel>

                    <!-- App Token -->
                    <TextBlock Text="앱 레벨 토큰 (xapp-...)" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel x:Name="SlackAppTokenInputPanel" Orientation="Horizontal">
                            <PasswordBox x:Name="SlackAppTokenInput" Width="320"
                                         FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                            <ui:Button Content="저장" Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                       Click="SaveSlackAppToken_Click" />
                        </StackPanel>
                        <StackPanel x:Name="SlackAppTokenSetPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock x:Name="SlackAppTokenStatus" Text="xapp-••••••••" FontSize="13"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <ui:Button Content="삭제" Appearance="Danger"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" FontSize="11"
                                       Click="DeleteSlackAppToken_Click" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="재시작" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="RestartSlack_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Slack Channels -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Slack 채널" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="새로고침" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Click="RefreshSlackChannels_Click" />
                    </DockPanel>

                    <ItemsControl x:Name="SlackChannelLinksPanel">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                                        <TextBlock Text="{Binding SpaceName}" FontSize="11"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="{Binding Enabled, Converter={StaticResource BoolToToggleTextConverter}}"
                                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4" Margin="0,0,4,0"
                                                   Click="ToggleSlackChannel_Click" Tag="{Binding}" />
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                   Padding="4" ToolTip="채널 삭제"
                                                   Click="DeleteSlackChannel_Click" Tag="{Binding}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoSlackChannelsText" Text="Slack 채널이 없습니다."
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Telegram Bot -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Telegram 봇" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="TelegramBotToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleTelegramBot_Click" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="TelegramBotStatusDot" Width="8" Height="8" Fill="{DynamicResource PawStatusDotIdle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="TelegramBotStatusText" Text="비활성" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                        <TextBlock x:Name="TelegramBotUsernameText" Text="" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="12,0,0,0" />
                    </StackPanel>

                    <!-- Bot Token -->
                    <TextBlock Text="봇 토큰 (BotFather에서 발급)" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel x:Name="TelegramBotTokenInputPanel" Orientation="Horizontal">
                            <PasswordBox x:Name="TelegramBotTokenInput" Width="360"
                                         FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                            <ui:Button Content="저장" Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                       Click="SaveTelegramBotToken_Click" />
                        </StackPanel>
                        <StackPanel x:Name="TelegramBotTokenSetPanel" Orientation="Horizontal" Visibility="Collapsed">
                            <TextBlock x:Name="TelegramBotTokenStatus" Text="••••••••" FontSize="13"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <ui:Button Content="삭제" Appearance="Danger"
                                       FontFamily="{StaticResource PawFont}" Padding="10,4" FontSize="11"
                                       Click="DeleteTelegramBotToken_Click" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="재시작" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="RestartTelegram_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Telegram Chats -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Telegram 채팅" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="새로고침" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Click="RefreshTelegramChats_Click" />
                    </DockPanel>

                    <ItemsControl x:Name="TelegramChatLinksPanel">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                                        <TextBlock Text="{Binding SpaceName}" FontSize="11"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="{Binding Enabled, Converter={StaticResource BoolToToggleTextConverter}}"
                                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4" Margin="0,0,4,0"
                                                   Click="ToggleTelegramChat_Click" Tag="{Binding}" />
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                   Padding="4" ToolTip="채팅 삭제"
                                                   Click="DeleteTelegramChat_Click" Tag="{Binding}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoTelegramChatsText" Text="Telegram 채팅이 없습니다. 봇에게 메시지를 보내면 자동 등록됩니다."
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Claude CLI -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Claude CLI" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="ClaudeCliToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleClaudeCli_Click" />
                    </DockPanel>

                    <TextBlock Text="로컬에 설치된 Claude CLI(claude 명령어)를 AI 엔진으로 사용한다. API 키 없이 Claude 모델을 호출할 수 있다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ClaudeCliStatusDot" Width="8" Height="8"
                                 Fill="{DynamicResource PawStatusDotIdle}"
                                 Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeCliStatusText" Text="확인 중..."
                                   FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <ui:Button Content="연결 확인" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4"
                                   Click="TestClaudeCli_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI Engine API Keys -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="AI 엔진 API 키" FontSize="16" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,4" />
                    <TextBlock Text="페르소나가 사용하는 AI 모델의 API 키를 관리한다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,12" />

                    <!-- Claude -->
                    <TextBlock Text="Claude (Anthropic)" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,6" />
                    <StackPanel x:Name="ClaudeKeyInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                        <PasswordBox x:Name="ClaudeKeyInput" Width="320"
                                     FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                        <ui:Button Content="저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                   Click="SaveClaudeKey_Click" />
                    </StackPanel>
                    <StackPanel x:Name="ClaudeKeySetPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="Collapsed">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeKeyMasked" Text="" FontSize="12"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Content="삭제" Appearance="Danger"
                                   FontFamily="{StaticResource PawFont}" Padding="8,4" FontSize="11"
                                   Click="DeleteClaudeKey_Click" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource PawBorder}" Margin="0,4,0,8" />

                    <!-- Gemini -->
                    <TextBlock Text="Gemini (Google)" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,6" />
                    <StackPanel x:Name="GeminiKeyInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                        <PasswordBox x:Name="GeminiKeyInput" Width="320"
                                     FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                        <ui:Button Content="저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                   Click="SaveGeminiKey_Click" />
                    </StackPanel>
                    <StackPanel x:Name="GeminiKeySetPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="Collapsed">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="GeminiKeyMasked" Text="" FontSize="12"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Content="삭제" Appearance="Danger"
                                   FontFamily="{StaticResource PawFont}" Padding="8,4" FontSize="11"
                                   Click="DeleteGeminiKey_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- App Info -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="앱 정보" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button DockPanel.Dock="Right" Content="업데이트 확인"
                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Padding="10,4"
                                   Click="CheckForUpdate_Click"
                                   IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBoolConverter}}" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="Agent Paw v" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                        <TextBlock Text="{Binding CurrentVersion}" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                        <TextBlock Text=" (WPF)" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>
                    <TextBlock Text=".NET 10 + CommunityToolkit.Mvvm + WPF-UI" FontSize="11"
                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                               Margin="0,2,0,0" />

                    <!-- Update Available Banner -->
                    <Border Margin="0,12,0,0" Padding="12,10" CornerRadius="8" BorderThickness="1"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisConverter}}">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.08" />
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                        </Border.BorderBrush>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Foreground="{DynamicResource PawSystemGreen}"
                                                   FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="새 버전 v" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LatestVersion}" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text=" 사용 가능" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <ui:Button DockPanel.Dock="Right" Content="지금 설치"
                                           Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                           HorizontalAlignment="Right" Padding="10,4"
                                           Click="InstallUpdate_Click"
                                           IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource InverseBoolConverter}}" />
                            </DockPanel>
                            <TextBlock Text="{Binding UpdateReleaseNotes}" FontSize="11"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       TextWrapping="Wrap" />
                            <ProgressBar Height="6" Margin="0,8,0,0"
                                         Value="{Binding UpdateDownloadProgress}" Maximum="100"
                                         Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</UserControl>
