<UserControl x:Class="AgentPaw.Views.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Loaded="SettingsPage_Loaded">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                           VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="환경 설정"
                           FontSize="24" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}" />
            </StackPanel>

            <!-- Messages -->
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=SuccessText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.1" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource PawSystemGreen}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="SuccessText"
                               Foreground="{DynamicResource PawSystemGreen}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Google Chat Bot -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Google Chat 봇" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="BotToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleBot_Click" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Ellipse x:Name="BotStatusDot" Width="8" Height="8" Fill="{DynamicResource PawStatusDotIdle}" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="BotStatusText" Text="중지됨" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>

                    <TextBlock Text="GCP Project ID" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="GcpProjectInput" PlaceholderText="my-project-id"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <TextBlock Text="Pub/Sub Topic" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="TopicInput" PlaceholderText="projects/xxx/topics/xxx"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <TextBlock Text="Pub/Sub Subscription" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="SubscriptionInput" PlaceholderText="projects/xxx/subscriptions/xxx"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="서비스 계정" FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" VerticalAlignment="Center" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="ServiceAccountStatus" Text="미설정" FontSize="11"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="0,0,8,0" />
                            <ui:Button Content="JSON 업로드" Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}" Padding="8,4"
                                       Click="UploadServiceAccount_Click" />
                        </StackPanel>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="PubSub 재시작" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="RestartPubSub_Click" />
                        <ui:Button Content="설정 저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="SaveBotConfig_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- WebSocket Server -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="WebSocket 서버" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <TextBlock x:Name="WsStatusText" Text="포트 8765" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,0" />
                    </StackPanel>
                    <ui:Button x:Name="WsToggleButton" Content="시작"
                               DockPanel.Dock="Right" Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Click="ToggleWebSocket_Click" />
                </DockPanel>
            </Border>

            <!-- Google Chat Spaces -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <TextBlock Text="Google Chat 스페이스" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="새로고침" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Click="RefreshSpaces_Click" />
                    </DockPanel>

                    <ItemsControl x:Name="SpaceLinksPanel">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,8">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                                        <TextBlock Text="{Binding SpaceName}" FontSize="11"
                                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <ui:Button Content="{Binding Enabled, Converter={StaticResource BoolToToggleTextConverter}}"
                                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4" Margin="0,0,4,0"
                                                   Click="ToggleSpace_Click" Tag="{Binding}" />
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                   Padding="4" ToolTip="스페이스 삭제"
                                                   Click="DeleteSpace_Click" Tag="{Binding}" />
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="NoSpacesText" Text="등록된 스페이스가 없다."
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,8,0,0" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</UserControl>
