<UserControl x:Class="AgentPaw.Views.Pages.LoginPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EDE8DC" Offset="0" />
                <GradientStop Color="#F5F0E8" Offset="0.5" />
                <GradientStop Color="#E8E0D0" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Paper grain texture -->
        <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
        <!-- Paw print background pattern -->
        <Border Background="{StaticResource PawPrintLoginBrush}" IsHitTestVisible="False" />

        <!-- Scattered decorative paw prints (asymmetric, matching mockup) -->
        <Canvas IsHitTestVisible="False">
            <!-- Top-left cluster -->
            <TextBlock Text="&#x1F43E;" FontSize="32" Opacity="0.06"
                       Canvas.Left="60" Canvas.Top="80">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-25" />
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F43E;" FontSize="22" Opacity="0.04"
                       Canvas.Left="120" Canvas.Top="40">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="10" />
                </TextBlock.RenderTransform>
            </TextBlock>
            <!-- Top-right -->
            <TextBlock Text="&#x1F43E;" FontSize="28" Opacity="0.05"
                       Canvas.Right="100" Canvas.Top="60">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="30" />
                </TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F43E;" FontSize="18" Opacity="0.04"
                       Canvas.Right="180" Canvas.Top="120">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-10" />
                </TextBlock.RenderTransform>
            </TextBlock>
            <!-- Bottom-left -->
            <TextBlock Text="&#x1F43E;" FontSize="24" Opacity="0.05"
                       Canvas.Left="80" Canvas.Bottom="100">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="45" />
                </TextBlock.RenderTransform>
            </TextBlock>
            <!-- Bottom-right -->
            <TextBlock Text="&#x1F43E;" FontSize="36" Opacity="0.05"
                       Canvas.Right="70" Canvas.Bottom="80">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-20" />
                </TextBlock.RenderTransform>
            </TextBlock>
        </Canvas>

        <!-- Dog breed parade (subtle, flanking the card — design mockup style) -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                    Margin="40,0,0,0" Opacity="0.12" IsHitTestVisible="False">
            <TextBlock Text="&#x1F415;" FontSize="28" Margin="0,0,0,20">
                <TextBlock.RenderTransform><RotateTransform Angle="-5" /></TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F429;" FontSize="24" Margin="10,0,0,20">
                <TextBlock.RenderTransform><RotateTransform Angle="8" /></TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F9AE;" FontSize="26" Margin="5,0,0,0">
                <TextBlock.RenderTransform><RotateTransform Angle="-3" /></TextBlock.RenderTransform>
            </TextBlock>
        </StackPanel>

        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                    Margin="0,0,40,0" Opacity="0.12" IsHitTestVisible="False">
            <TextBlock Text="&#x1F436;" FontSize="26" Margin="0,0,0,20" HorizontalAlignment="Right">
                <TextBlock.RenderTransform><RotateTransform Angle="5" /></TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F9AE;" FontSize="22" Margin="0,0,10,20" HorizontalAlignment="Right">
                <TextBlock.RenderTransform><RotateTransform Angle="-8" /></TextBlock.RenderTransform>
            </TextBlock>
            <TextBlock Text="&#x1F415;" FontSize="28" Margin="0,0,5,0" HorizontalAlignment="Right">
                <TextBlock.RenderTransform><RotateTransform Angle="3" /></TextBlock.RenderTransform>
            </TextBlock>
        </StackPanel>

        <!-- Centered Login Card -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="420" MinHeight="420"
                CornerRadius="14"
                Padding="40,36"
                Background="{DynamicResource PawCardBg}"
                BorderBrush="{DynamicResource PawBorder}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="40" Opacity="0.12" ShadowDepth="6" Color="#8B7355" />
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <!-- Mascot Dog (scholarly dog with glasses — matching mockup bottom-left) -->
                <Border Width="80" Height="80"
                        CornerRadius="40"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FAF7F2" Offset="0" />
                            <GradientStop Color="#EDE8DC" Offset="1" />
                        </RadialGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C8A96E" Offset="0" />
                            <GradientStop Color="#D4C4A8" Offset="1" />
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>2</Border.BorderThickness>
                    <Grid>
                        <TextBlock Text="&#x1F436;" FontSize="40"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="&#x1F453;" FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,2,0,6"
                                   Opacity="0.9" />
                    </Grid>
                </Border>

                <!-- Title -->
                <TextBlock Text="Agent Paw"
                           FontSize="28" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <!-- Subtitle -->
                <TextBlock Text="Product Agentic Workflow"
                           FontSize="13"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32" />

                <!-- Gold separator -->
                <Border Height="2" Width="80"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,32"
                        CornerRadius="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00C8A96E" Offset="0" />
                            <GradientStop Color="#C8A96E" Offset="0.5" />
                            <GradientStop Color="#00C8A96E" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Google Login Button -->
                <ui:Button x:Name="GoogleLoginButton"
                           HorizontalAlignment="Center"
                           MinWidth="260" Height="44"
                           Appearance="Primary"
                           FontFamily="{StaticResource PawFont}"
                           Click="GoogleLoginButton_Click"
                           IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}, FallbackValue=True}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="G" FontSize="18" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,10,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Sign in with Google"
                                   FontFamily="{StaticResource PawFont}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </ui:Button>

                <!-- Loading indicator -->
                <ui:ProgressRing Width="24" Height="24"
                                 Foreground="{DynamicResource PawGold}"
                                 Margin="0,16,0,0"
                                 HorizontalAlignment="Center"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />

                <!-- 남은 로그인 시간 -->
                <TextBlock Text="{Binding RemainingSeconds, StringFormat='남은 로그인 시간: {0}초'}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />

                <!-- Cancel button — 브라우저를 닫았거나 타임아웃을 기다리기 싫을 때 대기 상태를 해제한다 -->
                <ui:Button HorizontalAlignment="Center"
                           MinWidth="120" Height="32"
                           Margin="0,12,0,0"
                           Appearance="Secondary"
                           FontFamily="{StaticResource PawFont}"
                           Content="취소"
                           Command="{Binding CancelLoginCommand}"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />

                <!-- Error message -->
                <TextBlock x:Name="ErrorText"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PawErrorRed}"
                           FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           Margin="0,12,0,0"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
