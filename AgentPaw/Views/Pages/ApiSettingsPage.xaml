<UserControl x:Class="AgentPaw.Views.Pages.ApiSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:AgentPaw.ViewModels">

    <Grid>
        <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
        <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

        <Grid Margin="24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock FontSize="18" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}">
                    <Run Text="API 설정" />
                </TextBlock>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PawErrorRed}"
                           FontFamily="{StaticResource PawFont}" FontSize="12"
                           Margin="16,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Loading -->
                    <ui:ProgressRing Width="32" Height="32" Foreground="{DynamicResource PawGold}"
                                     HorizontalAlignment="Center" Margin="0,40,0,0"
                                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}}" />

                    <!-- Persona List -->
                    <ItemsControl ItemsSource="{Binding Personas}"
                                  Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,12">
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextPrimary}"
                                                           VerticalAlignment="Center" />
                                                <Border Background="{DynamicResource PawGoldTint}"
                                                        BorderBrush="{DynamicResource PawGold}"
                                                        BorderThickness="1" CornerRadius="3"
                                                        Padding="4,1" Margin="6,0,0,0"
                                                        Visibility="{Binding IsPm, Converter={StaticResource BoolToVisConverter}}">
                                                    <TextBlock Text="PM" FontSize="10" FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawGold}" FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding PrimaryModel}" FontSize="11"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        <ui:Button DockPanel.Dock="Right" Content="편집"
                                                   Icon="{ui:SymbolIcon Edit24}"
                                                   Appearance="Secondary"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Padding="10,4"
                                                   HorizontalAlignment="Right"
                                                   Click="EditPersona_Click" Tag="{Binding}" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Edit Panel (Slide-in overlay) -->
        <Border Background="{DynamicResource PawCardBg}"
                BorderBrush="{DynamicResource PawBorder}" BorderThickness="1,0,0,0"
                Width="360" HorizontalAlignment="Right"
                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}}">
            <Grid Margin="20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Edit Header -->
                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="{Binding SelectedPersona.Label}" FontSize="16" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" />
                    <ui:Button DockPanel.Dock="Right" Icon="{ui:SymbolIcon Dismiss24}"
                               Appearance="Transparent" Padding="4"
                               Command="{Binding CancelEditCommand}" />
                </DockPanel>

                <!-- Edit Fields -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Primary Model -->
                        <TextBlock Text="기본 모델" FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,6" />
                        <ComboBox ItemsSource="{Binding Source={x:Static vm:ApiSettingsViewModel.KnownModels}}"
                                  SelectedItem="{Binding EditPrimaryModel, Mode=TwoWay}"
                                  FontFamily="{StaticResource PawFont}" FontSize="12"
                                  Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditPrimaryModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource PawFont}" FontSize="12"
                                 VerticalContentAlignment="Center" Padding="8,5"
                                 Margin="0,0,0,16" />

                        <!-- Fallback Model -->
                        <TextBlock Text="폴백 모델 (선택)" FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,4" />
                        <TextBlock Text="기본 모델 실패 시 사용. 비워두면 폴백 없음."
                                   FontSize="10" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditFallbackModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource PawFont}" FontSize="12"
                                 VerticalContentAlignment="Center" Padding="8,5"
                                 Margin="0,0,0,16" />

                        <!-- Temperature -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Temperature" FontSize="12" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}" />
                            <TextBlock Text="{Binding EditTemperature, StringFormat='{}{0:F2}'}"
                                       DockPanel.Dock="Right" FontSize="12"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawGold}"
                                       FontWeight="SemiBold" />
                        </DockPanel>
                        <Slider Value="{Binding EditTemperature, Mode=TwoWay}"
                                Minimum="0.0" Maximum="1.0" TickFrequency="0.05"
                                IsSnapToTickEnabled="True" Margin="0,0,0,4" />
                        <TextBlock Text="낮을수록 일관성↑, 높을수록 창의성↑"
                                   FontSize="10" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,16" />

                        <!-- Max Tokens -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="Max Tokens" FontSize="12" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}" />
                            <TextBlock Text="{Binding EditMaxTokens}"
                                       DockPanel.Dock="Right" FontSize="12"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawGold}"
                                       FontWeight="SemiBold" />
                        </DockPanel>
                        <Slider Value="{Binding EditMaxTokens, Mode=TwoWay}"
                                Minimum="256" Maximum="32768" TickFrequency="256"
                                IsSnapToTickEnabled="True" Margin="0,0,0,4" />
                        <TextBlock Text="응답 1회당 최대 토큰 수"
                                   FontSize="10" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,16" />

                    </StackPanel>
                </ScrollViewer>

                <!-- Save / Cancel -->
                <StackPanel Grid.Row="2" Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="저장" Appearance="Primary" Padding="16,6"
                                   FontFamily="{StaticResource PawFont}"
                                   Command="{Binding SaveCommand}"
                                   IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBoolConverter}}" />
                        <ui:ProgressRing Width="18" Height="18" Margin="10,0,0,0"
                                         Foreground="{DynamicResource PawGold}" VerticalAlignment="Center"
                                         Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisConverter}}" />
                        <TextBlock Text="{Binding SaveMessage}" Margin="10,0,0,0"
                                   VerticalAlignment="Center" FontSize="11"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" />
                        <ui:Button Content="취소" Appearance="Secondary" Padding="12,6" Margin="8,0,0,0"
                                   FontFamily="{StaticResource PawFont}"
                                   Command="{Binding CancelEditCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource PawErrorRed}"
                               FontFamily="{StaticResource PawFont}" FontSize="11"
                               Margin="0,8,0,0" TextWrapping="Wrap"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
