<UserControl x:Class="AgentPaw.Views.Pages.DevAgentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls"
             xmlns:vm="clr-namespace:AgentPaw.ViewModels">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Left: project list -->
            <ColumnDefinition Width="220" MinWidth="160" MaxWidth="300" />
            <!-- Right: chat -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             LEFT PANEL — 프로젝트 목록
        ══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource PawBorder}"
                Background="{DynamicResource PawCardBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Panel header -->
                <Border Grid.Row="0" Padding="12,10"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource PawBorder}">
                    <DockPanel>
                        <ui:Button DockPanel.Dock="Right"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Appearance="Secondary"
                                   Padding="6,4"
                                   ToolTip="새 프로젝트"
                                   Command="{Binding NewProjectCommand}" />
                        <TextBlock Text="개발 프로젝트"
                                   FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- Project list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- New project entry -->
                        <Border Margin="6,6,6,2" Padding="10,8" CornerRadius="6"
                                Cursor="Hand"
                                MouseLeftButtonUp="NewProjectItem_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProject}" Value="{x:Null}">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.12" />
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.08" />
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Add24" FontSize="13"
                                               Foreground="{DynamicResource PawGold}"
                                               VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Text="새 프로젝트"
                                           FontSize="12" FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextPrimary}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Existing projects -->
                        <ItemsControl ItemsSource="{Binding DevProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DevProjectRecord}">
                                    <Border Margin="6,2" Padding="10,8" CornerRadius="6"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonUp="ProjectItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.08" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="12" FontWeight="Medium"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextPrimary}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding RelativeTime}"
                                                       FontSize="10"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: actions + root path -->
                <Border Grid.Row="2" Padding="10,8"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource PawBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <ui:Button Content="폴더"
                                       Icon="{ui:SymbolIcon Folder24}"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       FontSize="11" Padding="6,4"
                                       Margin="0,0,4,0"
                                       ToolTip="탐색기에서 열기"
                                       Command="{Binding OpenInExplorerCommand}" />
                            <ui:Button Content="VS Code"
                                       Icon="{ui:SymbolIcon Code24}"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       FontSize="11" Padding="6,4"
                                       ToolTip="VS Code로 열기"
                                       Command="{Binding OpenInVsCodeCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding DevProjectsRoot}"
                                   FontSize="9"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding DevProjectsRoot}"
                                   Cursor="Hand"
                                   MouseLeftButtonUp="RootPath_Click" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             RIGHT PANEL — 채팅
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
            <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="20,10"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource PawBorder}">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource PawCreamColor}" />
                    </Border.Background>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Code24" FontSize="16"
                                           Foreground="{DynamicResource PawGold}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                            <!-- 프로젝트명 (없으면 "새 프로젝트") -->
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding SelectedProject.Name}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedProject}" Value="{x:Null}">
                                                <Setter Property="Text" Value="새 프로젝트" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <!-- 경로 (없으면 저장 루트) -->
                        <TextBlock FontSize="10"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="24,1,0,0"
                                   Opacity="0.8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding SelectedProject.Path}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProject}" Value="{x:Null}">
                                            <Setter Property="Text" Value="{Binding DevProjectsRoot}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Messages -->
                <ScrollViewer Grid.Row="1"
                              x:Name="MessagesScroll"
                              VerticalScrollBarVisibility="Auto"
                              Padding="24,16,24,0">
                    <ItemsControl x:Name="MessagesList"
                                  ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <!-- User message (right) -->
                                    <Border HorizontalAlignment="Right"
                                            MaxWidth="680"
                                            Padding="14,10"
                                            CornerRadius="14,2,14,14"
                                            BorderThickness="1"
                                            Visibility="{Binding IsUser,
                                                Converter={StaticResource BoolToVisConverter}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.12" />
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.35" />
                                        </Border.BorderBrush>
                                        <TextBlock Text="{Binding Content}"
                                                   FontFamily="{StaticResource PawFont}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <!-- Assistant message (left) -->
                                    <Border HorizontalAlignment="Left"
                                            MaxWidth="760"
                                            Padding="14,10"
                                            CornerRadius="2,14,14,14"
                                            BorderThickness="1"
                                            Visibility="{Binding IsAssistant,
                                                Converter={StaticResource BoolToVisConverter}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="#2A2420" Opacity="0.85" />
                                        </Border.Background>
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.15" />
                                        </Border.BorderBrush>
                                        <StackPanel>
                                            <controls:MarkdownPresenter
                                                Content="{Binding Content}"
                                                Foreground="{DynamicResource PawTextPrimary}"
                                                FontFamily="{StaticResource PawFont}"
                                                FontSize="13" />
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,8,0,0"
                                                        Visibility="{Binding IsStreaming,
                                                            Converter={StaticResource BoolToVisConverter}}">
                                                <ui:ProgressRing Width="12" Height="12"
                                                                 IsIndeterminate="True"
                                                                 Foreground="{DynamicResource PawGold}"
                                                                 VerticalAlignment="Center"
                                                                 Margin="0,0,6,0" />
                                                <TextBlock Text="코드 작성 중…"
                                                           FontSize="11"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextSecondary}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Input area -->
                <Border Grid.Row="2"
                        Padding="20,10,20,16"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource PawBorder}">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource PawCreamColor}" />
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="InputBox"
                                 Grid.Column="0"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource PawFont}"
                                 FontSize="13"
                                 Padding="12,8"
                                 VerticalContentAlignment="Center"
                                 TextWrapping="Wrap"
                                 MaxHeight="120"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 KeyDown="InputBox_KeyDown" />

                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    Margin="8,0,0,0" VerticalAlignment="Bottom">
                            <ui:Button Content="취소"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="10,8" Margin="0,0,6,0"
                                       Click="Cancel_Click"
                                       Visibility="{Binding IsRunning,
                                           Converter={StaticResource BoolToVisConverter}}" />
                            <ui:Button Content="전송"
                                       Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="14,8"
                                       Command="{Binding SendCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
