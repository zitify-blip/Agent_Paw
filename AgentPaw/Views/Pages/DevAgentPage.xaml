<UserControl x:Class="AgentPaw.Views.Pages.DevAgentPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls">

    <Grid>
        <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
        <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="24,12,24,12"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource PawBorder}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawCreamColor}" />
                </Border.Background>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Code24" FontSize="18"
                                   Foreground="{DynamicResource PawGold}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                    <StackPanel>
                        <TextBlock Text="개발 에이전트"
                                   FontSize="15" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}" />
                        <!-- 프로젝트 있을 때 경로 표시 -->
                        <TextBlock Text="{Binding WorkingDirectory}"
                                   FontSize="11"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Opacity="0.8" Margin="0,1,0,0"
                                   Visibility="{Binding WorkingDirectory,
                                       Converter={StaticResource NullToCollapsedConverter}}" />
                        <!-- 프로젝트 없을 때 안내 -->
                        <TextBlock Text="프로젝트를 먼저 선택하세요"
                                   FontSize="11"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawGold}"
                                   Opacity="0.8" Margin="0,1,0,0"
                                   Visibility="{Binding WorkingDirectory,
                                       Converter={StaticResource EmptyToVisibleConverter}}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Messages -->
            <ScrollViewer Grid.Row="1"
                          x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="24,16,24,0">
                <ItemsControl x:Name="MessagesList"
                              ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <!-- User message (right) -->
                                <Border HorizontalAlignment="Right"
                                        MaxWidth="680"
                                        Padding="14,10"
                                        CornerRadius="14,2,14,14"
                                        BorderThickness="1"
                                        Visibility="{Binding IsUser,
                                            Converter={StaticResource BoolToVisConverter}}">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.12" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.35" />
                                    </Border.BorderBrush>
                                    <TextBlock Text="{Binding Content}"
                                               FontFamily="{StaticResource PawFont}"
                                               FontSize="13"
                                               Foreground="{DynamicResource PawTextPrimary}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <!-- Assistant message (left) -->
                                <Border HorizontalAlignment="Left"
                                        MaxWidth="760"
                                        Padding="14,10"
                                        CornerRadius="2,14,14,14"
                                        BorderThickness="1"
                                        Visibility="{Binding IsAssistant,
                                            Converter={StaticResource BoolToVisConverter}}">
                                    <Border.Background>
                                        <SolidColorBrush Color="#2A2420" Opacity="0.85" />
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.15" />
                                    </Border.BorderBrush>
                                    <StackPanel>
                                        <controls:MarkdownPresenter
                                            Content="{Binding Content}"
                                            Foreground="{DynamicResource PawTextPrimary}"
                                            FontFamily="{StaticResource PawFont}"
                                            FontSize="13" />
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,8,0,0"
                                                    Visibility="{Binding IsStreaming,
                                                        Converter={StaticResource BoolToVisConverter}}">
                                            <ui:ProgressRing Width="12" Height="12"
                                                             IsIndeterminate="True"
                                                             Foreground="{DynamicResource PawGold}"
                                                             VerticalAlignment="Center"
                                                             Margin="0,0,6,0" />
                                            <TextBlock Text="응답 생성 중…"
                                                       FontSize="11"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Input area -->
            <Border Grid.Row="2"
                    Padding="24,10,24,16"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource PawBorder}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawCreamColor}" />
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="InputBox"
                             Grid.Column="0"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource PawFont}"
                             FontSize="13"
                             Padding="12,8"
                             VerticalContentAlignment="Center"
                             TextWrapping="Wrap"
                             MaxHeight="120"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             KeyDown="InputBox_KeyDown" />

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Margin="8,0,0,0" VerticalAlignment="Bottom">
                        <ui:Button Content="취소"
                                   Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Padding="10,8" Margin="0,0,6,0"
                                   Click="Cancel_Click"
                                   Visibility="{Binding IsRunning,
                                       Converter={StaticResource BoolToVisConverter}}" />
                        <ui:Button Content="전송"
                                   Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Padding="14,8"
                                   Command="{Binding SendCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
