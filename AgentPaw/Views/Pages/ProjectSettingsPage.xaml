<UserControl x:Class="AgentPaw.Views.Pages.ProjectSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls"
             Loaded="ProjectSettingsPage_Loaded"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="&#x1F43E;" FontSize="16" Margin="0,0,6,0"
                           VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock FontSize="18" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}">
                    <Run Text="프로젝트 설정" />
                    <Run x:Name="ProjectNameText" Text="" FontWeight="Normal"
                         Foreground="{DynamicResource PawTextSecondary}" />
                </TextBlock>
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Workspace Folder -->
                <Border x:Name="WorkspaceCard" Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="작업 폴더 (Workspace)" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="에이전트가 파일을 만들거나 읽는 루트 폴더. 비워두면 기본 경로 사용."
                                   FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="0,0,0,10" />

                        <DockPanel Margin="0,0,0,8">
                            <ui:Button DockPanel.Dock="Right" Content="찾아보기" Padding="10,4"
                                       FontFamily="{StaticResource PawFont}"
                                       Margin="6,0,0,0"
                                       Click="BrowseWorkspace_Click" />
                            <TextBox x:Name="WorkspacePathInput"
                                     Text="{Binding WorkspacePath, UpdateSourceTrigger=PropertyChanged}"
                                     FontFamily="{StaticResource PawFont}"
                                     VerticalContentAlignment="Center" Padding="8,6" />
                        </DockPanel>

                        <TextBlock FontSize="10" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="0,0,0,10">
                            <Run Text="현재 적용: " />
                            <Run Text="{Binding EffectiveWorkspacePath}" FontWeight="SemiBold" />
                        </TextBlock>

                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="저장" Appearance="Primary" Padding="12,4"
                                       FontFamily="{StaticResource PawFont}"
                                       Command="{Binding SaveWorkspacePathCommand}" />
                            <ui:Button Content="탐색기로 열기" Padding="12,4" Margin="8,0,0,0"
                                       FontFamily="{StaticResource PawFont}"
                                       Command="{Binding OpenWorkspaceFolderCommand}" />
                            <TextBlock Text="{Binding WorkspaceSaveMessage}" Margin="12,0,0,0"
                                       VerticalAlignment="Center" FontSize="11"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Git Clone -->
                <Border x:Name="CloneCard" Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Git 레포 클론" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="원격 레포를 작업 폴더로 클론한다. 비공개 레포는 Personal Access Token을 입력한다."
                                   FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="레포 URL" FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                        <TextBox Text="{Binding CloneUrl, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="{StaticResource PawFont}"
                                 VerticalContentAlignment="Center" Padding="8,6"
                                 Margin="0,0,0,8"
                                 IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBoolConverter}}" />

                        <TextBlock Text="Access Token (비공개 레포, 선택)" FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                        <PasswordBox x:Name="CloneTokenBox"
                                     FontFamily="{StaticResource PawFont}"
                                     Padding="8,6"
                                     Margin="0,0,0,12"
                                     PasswordChanged="CloneTokenBox_PasswordChanged" />

                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="클론" Appearance="Primary" Padding="14,4"
                                       FontFamily="{StaticResource PawFont}"
                                       Command="{Binding CloneRepoCommand}"
                                       IsEnabled="{Binding IsCloning, Converter={StaticResource InverseBoolConverter}}" />
                            <ui:ProgressRing Width="18" Height="18" Margin="10,0,0,0"
                                             Foreground="{DynamicResource PawGold}"
                                             VerticalAlignment="Center"
                                             Visibility="{Binding IsCloning, Converter={StaticResource BoolToVisConverter}}" />
                            <TextBlock Text="{Binding CloneMessage}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" FontSize="11"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}"
                                       TextWrapping="Wrap" MaxWidth="300" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- 대화 설정 -->
                <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="대화 설정" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="토론 라운드 수·참여자 수·PM 재질의 허용 여부를 프로젝트별로 설정한다."
                                   FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   Margin="0,0,0,16" />

                        <!-- 최대 토론 라운드 -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="최대 토론 라운드"
                                       FontSize="13" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}"
                                       VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding MaxDiscussionRounds, StringFormat={}{0}라운드}"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawGold}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </DockPanel>
                        <Slider Minimum="1" Maximum="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding MaxDiscussionRounds, Mode=TwoWay}"
                                Margin="0,0,0,16" />

                        <!-- 최대 참여자 수 -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="최대 참여자 수"
                                       FontSize="13" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}"
                                       VerticalAlignment="Center" />
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding MaxDiscussionParticipants, StringFormat={}{0}명}"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawGold}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </DockPanel>
                        <Slider Minimum="2" Maximum="8"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Value="{Binding MaxDiscussionParticipants, Mode=TwoWay}"
                                Margin="0,0,0,16" />

                        <!-- PM 재질의 허용 -->
                        <CheckBox IsChecked="{Binding AskUserEnabled}"
                                  Content="PM이 사용자에게 재질의(pm_intervention)할 수 있도록 허용"
                                  FontFamily="{StaticResource PawFont}"
                                  FontSize="13"
                                  Foreground="{DynamicResource PawTextPrimary}"
                                  Margin="0,0,0,16" />

                        <!-- 저장 -->
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="저장" Appearance="Primary" Padding="12,4"
                                       FontFamily="{StaticResource PawFont}"
                                       Command="{Binding SaveDiscussionSettingsCommand}" />
                            <TextBlock Text="{Binding DiscussionSaveMessage}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" FontSize="11"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Personas -->
                <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="페르소나" FontSize="16" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}" />
                            <ui:Button Content="연결" Icon="{ui:SymbolIcon Link24}"
                                       DockPanel.Dock="Right" Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Right" Padding="8,4"
                                       ToolTip="페르소나 메뉴에 등록된 페르소나를 이 프로젝트에 연결한다"
                                       Click="OpenPersonaLinkDialog_Click" />
                        </DockPanel>

                        <!-- Grouped persona list (Masonry 2-column) -->
                        <ItemsControl x:Name="GroupsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:MasonryPanel Columns="2" ColumnSpacing="12" RowSpacing="12" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,10"
                                            Background="{DynamicResource PawCardBg}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,6">
                                                <ui:Button DockPanel.Dock="Right" Icon="{ui:SymbolIcon Dismiss24}"
                                                           Appearance="Transparent" Padding="4"
                                                           ToolTip="그룹 전체 연결 해제"
                                                           Click="UnlinkPersonaGroup_Click" Tag="{Binding}" />
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x1F4C1;" FontSize="13" Margin="0,0,6,0"
                                                               VerticalAlignment="Center" Opacity="0.7" />
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock FontSize="10" FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextSecondary}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Run Text="(" /><Run Text="{Binding Personas.Count, Mode=OneWay}" /><Run Text=")" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Personas}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                                Background="{DynamicResource PawCreamBrush}"
                                                                BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                                            <DockPanel>
                                                                <Grid DockPanel.Dock="Left" Width="40" Height="40"
                                                                      Margin="0,0,12,0" VerticalAlignment="Center">
                                                                    <Border CornerRadius="0" Width="40" Height="40"
                                                                            Background="{DynamicResource PawCreamBrush}"
                                                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                                            Visibility="{Binding Avatar, Converter={StaticResource EmptyToVisibleConverter}}">
                                                                        <TextBlock Text="&#x1F43E;" FontSize="18"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <Border CornerRadius="0" Width="40" Height="40"
                                                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                                            Visibility="{Binding Avatar, Converter={StaticResource NotEmptyToVisibleConverter}}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding Avatar, Converter={StaticResource AvatarToImageConverter}}"
                                                                                        Stretch="UniformToFill" />
                                                                        </Border.Background>
                                                                    </Border>
                                                                </Grid>
                                                                <StackPanel DockPanel.Dock="Left" MaxWidth="500">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"
                                                                                   FontFamily="{StaticResource PawFont}"
                                                                                   Foreground="{DynamicResource PawTextPrimary}" />
                                                                        <Border Background="{DynamicResource PawGoldTint}" CornerRadius="3" Padding="4,1"
                                                                                Margin="8,0,0,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding PrimaryModel}" FontSize="10"
                                                                                       FontFamily="{StaticResource PawFont}"
                                                                                       Foreground="{DynamicResource PawGold}" />
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                                               FontFamily="{StaticResource PawFont}"
                                                                               Foreground="{DynamicResource PawTextSecondary}"
                                                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                    <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                                                                               Padding="4" ToolTip="연결 해제"
                                                                               Click="UnlinkPersona_Click" Tag="{Binding}" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Ungrouped personas -->
                        <StackPanel x:Name="UngroupedSection">
                            <TextBlock Text="미분류" FontSize="11" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,6" />
                            <ItemsControl x:Name="UngroupedList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,6"
                                                Background="{DynamicResource PawCreamBrush}"
                                                BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                            <DockPanel>
                                                <Grid DockPanel.Dock="Left" Width="40" Height="40"
                                                      Margin="0,0,12,0" VerticalAlignment="Center">
                                                    <Border CornerRadius="0" Width="40" Height="40"
                                                            Background="{DynamicResource PawCreamBrush}"
                                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                            Visibility="{Binding Avatar, Converter={StaticResource EmptyToVisibleConverter}}">
                                                        <TextBlock Text="&#x1F43E;" FontSize="18"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <Border CornerRadius="0" Width="40" Height="40"
                                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                            Visibility="{Binding Avatar, Converter={StaticResource NotEmptyToVisibleConverter}}">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding Avatar, Converter={StaticResource AvatarToImageConverter}}"
                                                                        Stretch="UniformToFill" />
                                                        </Border.Background>
                                                    </Border>
                                                </Grid>
                                                <StackPanel DockPanel.Dock="Left" MaxWidth="500">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Label}" FontSize="13" FontWeight="SemiBold"
                                                                   FontFamily="{StaticResource PawFont}"
                                                                   Foreground="{DynamicResource PawTextPrimary}" />
                                                        <Border Background="{DynamicResource PawGoldTint}" CornerRadius="3" Padding="4,1"
                                                                Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding PrimaryModel}" FontSize="10"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Foreground="{DynamicResource PawGold}" />
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Description}" FontSize="11"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextSecondary}"
                                                               Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                            HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                                                               Padding="4" ToolTip="연결 해제"
                                                               Click="UnlinkPersona_Click" Tag="{Binding}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock x:Name="NoPersonasText" Text="연결된 페르소나가 없다. [연결] 버튼으로 추가한다."
                                   FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>

                <!-- Linked Instructions -->
                <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,12">
                            <TextBlock Text="연결된 지침" FontSize="16" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}" />
                            <ui:Button Content="연결" Icon="{ui:SymbolIcon Link24}"
                                       DockPanel.Dock="Right" Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Right" Padding="8,4"
                                       ToolTip="지침 문서 연결"
                                       Click="OpenLinkDialog_Click" />
                        </DockPanel>

                        <!-- Grouped linked instructions (Masonry 2-column) -->
                        <ItemsControl x:Name="LinkedGroupsList">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:MasonryPanel Columns="2" ColumnSpacing="12" RowSpacing="12" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                                            Background="{DynamicResource PawCardBg}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x1F4C1;" FontSize="13" Margin="0,0,6,0"
                                                               VerticalAlignment="Center" Opacity="0.7" />
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock FontSize="10" FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextSecondary}"
                                                               VerticalAlignment="Center" Margin="6,0,0,0">
                                                        <Run Text="(" /><Run Text="{Binding Files.Count, Mode=OneWay}" /><Run Text=")" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                           Padding="2" ToolTip="그룹 전체 연결 해제"
                                                           Click="UnlinkInstructionGroup_Click" Tag="{Binding}" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="8,2,0,2">
                                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="11"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Foreground="{DynamicResource PawTextPrimary}"
                                                                       VerticalAlignment="Center" />
                                                            <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                                       Padding="2" ToolTip="연결 해제"
                                                                       Click="UnlinkInstruction_Click" Tag="{Binding}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Ungrouped linked files -->
                        <StackPanel x:Name="LinkedUngroupedSection">
                            <TextBlock Text="미분류" FontSize="11" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,6" />
                            <ItemsControl x:Name="LinkedUngroupedList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <ui:Button Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent"
                                                       DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                       Padding="2" ToolTip="연결 해제"
                                                       Click="UnlinkInstruction_Click" Tag="{Binding}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <TextBlock x:Name="NoLinkedText" Text="연결된 지침이 없다."
                                   FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing Width="40" Height="40"
                             Foreground="{DynamicResource PawGold}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Persona Link Dialog (전역 페르소나 → 프로젝트 연결) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="PersonaLinkDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="PersonaLinkDialogOverlay_Click">
            <Border Width="450" MaxHeight="500" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="페르소나 연결" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="닫기" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right" Padding="8,4"
                                   Click="PersonaLinkDialogClose_Click" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8"
                               Text="그룹 단위로 일괄 연결하거나, 페르소나 단위로 개별 연결한다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AvailablePersonaGroupsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Margin="0,0,0,8" Padding="8,6"
                                            Background="{DynamicResource PawCreamBrush}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextPrimary}"
                                                           VerticalAlignment="Center" />
                                                <ui:Button Content="그룹 전체 연결" DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right" Appearance="Primary"
                                                           Icon="{ui:SymbolIcon Link24}"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Padding="6,2" FontSize="11"
                                                           Click="LinkPersonaGroup_Click" Tag="{Binding}" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Personas}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="8,2,0,2">
                                                            <StackPanel DockPanel.Dock="Left">
                                                                <TextBlock Text="{Binding Label}" FontSize="11"
                                                                           FontFamily="{StaticResource PawFont}"
                                                                           Foreground="{DynamicResource PawTextPrimary}" />
                                                                <TextBlock Text="{Binding Description}" FontSize="9"
                                                                           FontFamily="{StaticResource PawFont}"
                                                                           Foreground="{DynamicResource PawTextSecondary}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <ui:Button Content="연결" DockPanel.Dock="Right"
                                                                       HorizontalAlignment="Right" Appearance="Secondary"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Padding="6,1" FontSize="10"
                                                                       Click="LinkPersona_Click" Tag="{Binding}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

        <!-- Link Instruction Dialog (그룹/파일 단위) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="LinkDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="LinkDialogOverlay_Click">
            <Border Width="450" MaxHeight="500" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="지침 연결" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="닫기" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right" Padding="8,4"
                                   Click="LinkDialogClose_Click" />
                    </DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8"
                               Text="그룹 단위로 일괄 연결하거나, 파일 단위로 개별 연결한다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" />
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AvailableInstructionGroupsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Margin="0,0,0,8" Padding="8,6"
                                            Background="{DynamicResource PawCreamBrush}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,4">
                                                <TextBlock DockPanel.Dock="Left"
                                                           Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextPrimary}"
                                                           VerticalAlignment="Center" />
                                                <ui:Button Content="그룹 전체 연결" DockPanel.Dock="Right"
                                                           HorizontalAlignment="Right" Appearance="Primary"
                                                           Icon="{ui:SymbolIcon Link24}"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Padding="6,2" FontSize="11"
                                                           Click="LinkInstructionGroup_Click" Tag="{Binding}" />
                                            </DockPanel>
                                            <ItemsControl ItemsSource="{Binding Files}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <DockPanel Margin="8,2,0,2">
                                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontSize="11"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Foreground="{DynamicResource PawTextPrimary}"
                                                                       VerticalAlignment="Center" />
                                                            <ui:Button Content="연결" DockPanel.Dock="Right"
                                                                       HorizontalAlignment="Right" Appearance="Secondary"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Padding="6,1" FontSize="10"
                                                                       Click="LinkInstruction_Click" Tag="{Binding}" />
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>

    </Grid>
    </Grid>
</UserControl>
