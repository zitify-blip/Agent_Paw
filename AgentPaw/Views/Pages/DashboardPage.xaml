<UserControl x:Class="AgentPaw.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls"
             Loaded="DashboardPage_Loaded"
             Focusable="True"
             PreviewKeyDown="Dialog_KeyDown">

    <Grid>
        <!-- Paper grain + Paw print -->
        <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
        <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

        <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                               VerticalAlignment="Center" Opacity="0.6" />
                    <TextBlock Text="프로젝트"
                               FontSize="24" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" />
                </StackPanel>
                <TextBlock Text="프로젝트를 생성하고 관리한다."
                           FontSize="13"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           Margin="0,4,0,0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="보관함"
                           Icon="{ui:SymbolIcon Archive24}"
                           Appearance="Secondary"
                           FontFamily="{StaticResource PawFont}"
                           Margin="0,0,8,0"
                           ToolTip="보관한 프로젝트 보기"
                           Click="ToggleArchived_Click" />
                <ui:Button Content="새 프로젝트"
                           Icon="{ui:SymbolIcon Add24}"
                           Appearance="Primary"
                           FontFamily="{StaticResource PawFont}"
                           ToolTip="새 프로젝트 생성"
                           Click="CreateProject_Click" />
            </StackPanel>
        </DockPanel>

        <!-- Error message -->
        <Border Grid.Row="1"
                Padding="12,10" CornerRadius="8"
                BorderThickness="1" Margin="0,0,0,12"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}, FallbackValue=Collapsed}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                               FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           TextWrapping="Wrap" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Project Grid (Active) -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowArchived, Converter={StaticResource InverseBoolToVisConverter}, FallbackValue=Visible}">
            <StackPanel>
                <!-- Empty state — Dog mascot (Corgi waiting) -->
                <StackPanel HorizontalAlignment="Center"
                            Visibility="{Binding Projects.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}">
                    <!-- Dog breed circle composition -->
                    <Border Width="100" Height="100" CornerRadius="50"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="#FAF7F2" Offset="0" />
                                <GradientStop Color="#EDE8DC" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#C8A96E" Offset="0" />
                                <GradientStop Color="#D4C4A8" Offset="1" />
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>2</Border.BorderThickness>
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20" Opacity="0.1" ShadowDepth="3" Color="#8B7355" />
                        </Border.Effect>
                        <Grid>
                            <TextBlock Text="&#x1F436;" FontSize="48"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,0,0,4" />
                            <!-- Sad waiting eyes -->
                            <TextBlock Text="&#x1F4AD;" FontSize="16"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Margin="0,-4,-8,0" Opacity="0.7" />
                        </Grid>
                    </Border>
                    <!-- Paw trail (walking towards user) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F43E;" FontSize="12" Opacity="0.15" Margin="0,0,6,0">
                            <TextBlock.RenderTransform><RotateTransform Angle="-20" /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="&#x1F43E;" FontSize="14" Opacity="0.2" Margin="0,0,6,0">
                            <TextBlock.RenderTransform><RotateTransform Angle="10" /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="&#x1F43E;" FontSize="16" Opacity="0.25" Margin="0,0,6,0">
                            <TextBlock.RenderTransform><RotateTransform Angle="-15" /></TextBlock.RenderTransform>
                        </TextBlock>
                        <TextBlock Text="&#x1F43E;" FontSize="18" Opacity="0.3">
                            <TextBlock.RenderTransform><RotateTransform Angle="5" /></TextBlock.RenderTransform>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="아직 프로젝트가 없다"
                               FontSize="16" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="새 프로젝트를 생성해서 시작한다."
                               FontSize="13" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Project cards -->
                <ItemsControl ItemsSource="{Binding Projects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:MasonryPanel Columns="3" ColumnSpacing="16" RowSpacing="16" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinHeight="160"
                                    CornerRadius="8"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="ProjectCard_Click">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FDFBF8" Offset="0" />
                                        <GradientStop Color="#FAF7F2" Offset="0.4" />
                                        <GradientStop Color="#F7F3EC" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#DDD0B8" Offset="0" />
                                        <GradientStop Color="#C8B898" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" Opacity="0.12"
                                                      ShadowDepth="3" Direction="260"
                                                      Color="#7A6545" />
                                </Border.Effect>
                                <Grid Margin="20,16">
                                    <!-- Subtle paw watermark on card -->
                                    <TextBlock Text="&#x1F43E;" FontSize="48"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Bottom"
                                               Margin="0,0,-4,-4"
                                               Opacity="0.04"
                                               IsHitTestVisible="False">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="-20" />
                                        </TextBlock.RenderTransform>
                                    </TextBlock>

                                    <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Project name + role badge -->
                                    <DockPanel Grid.Row="0">
                                        <TextBlock Text="{Binding ProjectName}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <!-- 채팅 중 배지 -->
                                            <Border BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    Margin="0,0,4,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.1" />
                                                </Border.Background>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.27" />
                                                </Border.BorderBrush>
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource EqualityMultiConverter}"
                                                                  ConverterParameter="TrueToVisible">
                                                        <Binding Path="ProjectId" />
                                                        <Binding Path="DataContext.ActiveProjectId"
                                                                 RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="6" Height="6"
                                                             Fill="{DynamicResource PawSystemGreen}"
                                                             Margin="0,0,5,0"
                                                             VerticalAlignment="Center" />
                                                    <TextBlock Text="채팅 중"
                                                               FontSize="10"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawSystemGreen}" />
                                                </StackPanel>
                                            </Border>
                                            <Border Background="{DynamicResource PawGoldTint}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Role}"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawGold}" />
                                            </Border>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Description -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="48"
                                               Margin="0,8,0,0" />

                                    <!-- Footer: date + actions -->
                                    <DockPanel Grid.Row="2">
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}"
                                                   Opacity="0.6"
                                                   VerticalAlignment="Center" />
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Right">
                                            <ui:Button Icon="{ui:SymbolIcon Edit24}"
                                                       Appearance="Transparent"
                                                       Padding="4"
                                                       Click="EditProject_Click"
                                                       Tag="{Binding}"
                                                       ToolTip="편집" />
                                            <ui:Button Icon="{ui:SymbolIcon Archive24}"
                                                       Appearance="Transparent"
                                                       Padding="4"
                                                       Click="ArchiveProject_Click"
                                                       Tag="{Binding}"
                                                       ToolTip="보관" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       Appearance="Transparent"
                                                       Padding="4"
                                                       Click="DeleteProject_Click"
                                                       Tag="{Binding}"
                                                       ToolTip="삭제" />
                                        </StackPanel>
                                    </DockPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Archived Projects -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding ShowArchived, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <StackPanel>
                <StackPanel HorizontalAlignment="Center"
                            Visibility="{Binding ArchivedProjects.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}">
                    <TextBlock Text="보관된 프로젝트가 없다"
                               FontSize="16" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding ArchivedProjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:MasonryPanel Columns="3" ColumnSpacing="16" RowSpacing="16" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border MinHeight="140"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource PawBorder}"
                                    Opacity="0.7"
                                    Background="{DynamicResource PawArchiveBg}">
                                <Grid Margin="20,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding ProjectName}"
                                               FontSize="16" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawArchiveText}" />

                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawArchiveSubText}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="36"
                                               Margin="0,8,0,0" />

                                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <ui:Button Content="복원"
                                                   Appearance="Secondary"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4"
                                                   FontSize="11"
                                                   Margin="0,0,8,0"
                                                   ToolTip="프로젝트 복원"
                                                   Click="RestoreProject_Click"
                                                   Tag="{Binding}" />
                                        <ui:Button Content="삭제"
                                                   Appearance="Danger"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Padding="8,4"
                                                   FontSize="11"
                                                   Click="DeleteProject_Click"
                                                   Tag="{Binding}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing Width="40" Height="40"
                             Foreground="{DynamicResource PawGold}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Border>

        <!-- Create/Edit Dialog Overlay -->
        <Border Grid.Row="0" Grid.RowSpan="4"
                Panel.ZIndex="20"
                Background="#88A09080"
                Visibility="{Binding IsDialogOpen, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                MouseLeftButtonUp="DialogOverlay_Click">
            <Border Width="440" MinHeight="280"
                    CornerRadius="12"
                    Padding="32,28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}"
                    BorderThickness="1"
                    MouseLeftButtonUp="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" Opacity="0.15" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>

                <StackPanel>
                    <TextBlock x:Name="DialogTitle"
                               FontSize="20" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               Margin="0,0,0,20" />

                    <TextBlock Text="프로젝트 이름" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <ui:TextBox x:Name="ProjectNameInput"
                                Text="{Binding DialogProjectName, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="예: Agent Paw 기획"
                                FontFamily="{StaticResource PawFont}"
                                Margin="0,0,0,16" />

                    <TextBlock Text="설명 (선택)" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <ui:TextBox x:Name="ProjectDescInput"
                                Text="{Binding DialogProjectDescription, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="예: 팀 협업용 RAG 에이전트"
                                FontFamily="{StaticResource PawFont}"
                                AcceptsReturn="True"
                                MinHeight="60"
                                Margin="0,0,0,24" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="취소"
                                   Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0"
                                   Click="DialogCancel_Click" />
                        <ui:Button x:Name="DialogSaveButton"
                                   Content="저장"
                                   Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="DialogSave_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
    </Grid>
</UserControl>
