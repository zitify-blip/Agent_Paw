<UserControl x:Class="AgentPaw.Views.Pages.LlmSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Loaded="LlmSettingsPage_Loaded">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                           VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="LLM"
                           FontSize="24" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}" />
            </StackPanel>

            <!-- Messages -->
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=SuccessText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.1" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource PawSystemGreen}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="SuccessText"
                               Foreground="{DynamicResource PawSystemGreen}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- Claude CLI -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Claude CLI" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button x:Name="ClaudeCliToggleButton" Content="활성화"
                                   DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right"
                                   Click="ToggleClaudeCli_Click" />
                    </DockPanel>

                    <TextBlock Text="로컬에 설치된 Claude CLI(claude 명령어)를 AI 엔진으로 사용한다. API 키 없이 Claude 모델을 호출할 수 있다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" TextWrapping="Wrap"
                               Margin="0,0,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ClaudeCliStatusDot" Width="8" Height="8"
                                 Fill="{DynamicResource PawStatusDotIdle}"
                                 Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeCliStatusText" Text="확인 중..."
                                   FontSize="12" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <ui:Button Content="연결 확인" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4"
                                   Click="TestClaudeCli_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- AI Engine API Keys -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="AI 엔진 API 키" FontSize="16" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,4" />
                    <TextBlock Text="페르소나가 사용하는 AI 모델의 API 키를 관리한다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,12" />

                    <!-- Claude -->
                    <TextBlock Text="Claude (Anthropic)" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,6" />
                    <StackPanel x:Name="ClaudeKeyInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                        <PasswordBox x:Name="ClaudeKeyInput" Width="320"
                                     FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                        <ui:Button Content="저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                   Click="SaveClaudeKey_Click" />
                    </StackPanel>
                    <StackPanel x:Name="ClaudeKeySetPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="Collapsed">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="ClaudeKeyMasked" Text="" FontSize="12"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Content="삭제" Appearance="Danger"
                                   FontFamily="{StaticResource PawFont}" Padding="8,4" FontSize="11"
                                   Click="DeleteClaudeKey_Click" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource PawBorder}" Margin="0,4,0,8" />

                    <!-- Gemini -->
                    <TextBlock Text="Gemini (Google)" FontSize="13" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,6" />
                    <StackPanel x:Name="GeminiKeyInputPanel" Orientation="Horizontal" Margin="0,0,0,8">
                        <PasswordBox x:Name="GeminiKeyInput" Width="320"
                                     FontFamily="{StaticResource PawFont}" PasswordChar="*" MaxLength="200" />
                        <ui:Button Content="저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}" Padding="10,4" Margin="8,0,0,0"
                                   Click="SaveGeminiKey_Click" />
                    </StackPanel>
                    <StackPanel x:Name="GeminiKeySetPanel" Orientation="Horizontal" Margin="0,0,0,8"
                                Visibility="Collapsed">
                        <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="GeminiKeyMasked" Text="" FontSize="12"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ui:Button Content="삭제" Appearance="Danger"
                                   FontFamily="{StaticResource PawFont}" Padding="8,4" FontSize="11"
                                   Click="DeleteGeminiKey_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</UserControl>
