<UserControl x:Class="AgentPaw.Views.Pages.InstructionsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls"
             Loaded="InstructionsPage_Loaded"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                               VerticalAlignment="Center" Opacity="0.6" />
                    <TextBlock Text="지침"
                               FontSize="24" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" />
                </StackPanel>
                <TextBlock Text="AI 페르소나가 참조할 지침 파일과 그룹을 관리한다."
                           FontSize="13" FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="새 그룹"
                           Icon="{ui:SymbolIcon FolderAdd24}"
                           Appearance="Secondary"
                           FontFamily="{StaticResource PawFont}"
                           Margin="0,0,8,0"
                           ToolTip="지침 그룹 생성"
                           Click="CreateGroup_Click" />
                <ui:Button Content="파일 업로드"
                           Icon="{ui:SymbolIcon ArrowUpload24}"
                           Appearance="Primary"
                           FontFamily="{StaticResource PawFont}"
                           Margin="0,0,8,0"
                           ToolTip="로컬 파일을 지침으로 추가"
                           Click="UploadFiles_Click" />
                <ui:Button Content="새 파일"
                           Icon="{ui:SymbolIcon DocumentAdd24}"
                           Appearance="Secondary"
                           FontFamily="{StaticResource PawFont}"
                           ToolTip="빈 지침 파일 생성"
                           Click="CreateFile_Click" />
            </StackPanel>
        </DockPanel>

        <!-- Error -->
        <Border Grid.Row="1" Padding="10,8" CornerRadius="8" BorderThickness="1"
                VerticalAlignment="Top" HorizontalAlignment="Left"
                Panel.ZIndex="5"
                Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Groups (Pinterest/Masonry 2-column layout) -->
                <ItemsControl x:Name="GroupsList" Margin="0,0,0,12">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:MasonryPanel Columns="2" ColumnSpacing="12" RowSpacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PawCardStyle}">
                                <StackPanel>
                                    <!-- Accordion header -->
                                    <DockPanel Margin="0" Cursor="Hand"
                                               MouseLeftButtonDown="ToggleGroup_Click" Tag="{Binding}">
                                        <TextBlock FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Name}" />
                                            <Run Text=" (" Foreground="{DynamicResource PawTextSecondary}" /><Run Text="{Binding FileCount}" Foreground="{DynamicResource PawTextSecondary}" /><Run Text=")" Foreground="{DynamicResource PawTextSecondary}" />
                                        </TextBlock>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock x:Name="ChevronIcon" Text="▾" FontSize="12"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       VerticalAlignment="Center" Margin="0,0,6,0"
                                                       RenderTransformOrigin="0.5,0.5">
                                                <TextBlock.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                            <ui:Button Icon="{ui:SymbolIcon ArrowUpload24}" Appearance="Transparent"
                                                       Padding="4" ToolTip="파일 업로드"
                                                       Click="UploadFilesToGroup_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon DocumentAdd24}" Appearance="Transparent"
                                                       Padding="4" ToolTip="새 파일 만들기"
                                                       Click="CreateFileInGroup_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon Edit24}" Appearance="Transparent"
                                                       Padding="4" ToolTip="이름 변경"
                                                       Click="EditGroup_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       Padding="4" ToolTip="그룹 삭제"
                                                       Click="DeleteGroup_Click" Tag="{Binding}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Collapsible file list -->
                                    <ItemsControl ItemsSource="{Binding Files}" Margin="0,8,0,0"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="12,0,0,4">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <ui:Button Icon="{ui:SymbolIcon Eye24}" Appearance="Transparent"
                                                                   Padding="2" ToolTip="미리보기"
                                                                   Click="PreviewFile_Click" Tag="{Binding}" />
                                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                                   Padding="2" ToolTip="삭제"
                                                                   Click="DeleteFile_Click" Tag="{Binding}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ungrouped files -->
                <Border x:Name="UngroupedSection" Style="{StaticResource PawCardStyle}" Margin="0,0,0,12"
                        Opacity="0.85">
                    <StackPanel>
                        <TextBlock Text="그룹 없는 파일" FontSize="14" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,8" />
                        <ItemsControl x:Name="UngroupedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   VerticalAlignment="Center" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <ui:Button Icon="{ui:SymbolIcon Eye24}" Appearance="Transparent"
                                                       Padding="2" ToolTip="미리보기"
                                                       Click="PreviewFile_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       Padding="2" ToolTip="삭제"
                                                       Click="DeleteFile_Click" Tag="{Binding}" />
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing Width="40" Height="40"
                             Foreground="{DynamicResource PawGold}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Group Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="GroupDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="GroupDialogOverlay_Click">
            <Border Width="400" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="GroupDialogTitle" Text="새 그룹" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,16" />
                    <TextBlock Text="그룹 이름" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="GroupNameInput" PlaceholderText="예: 백엔드 지침"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="취소" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0" Click="GroupDialogCancel_Click" />
                        <ui:Button Content="저장" Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                   Click="GroupDialogSave_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- File Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="FileDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="FileDialogOverlay_Click">
            <Border Width="500" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="새 지침 파일" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,16" />
                    <TextBlock Text="파일 이름" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="FileNameInput" PlaceholderText="예: system-prompt.md"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,12" />
                    <TextBlock Text="내용" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="FileContentInput" PlaceholderText="지침 내용..."
                                FontFamily="{StaticResource PawFont}"
                                AcceptsReturn="True" MinHeight="200" TextWrapping="Wrap" Margin="0,0,0,20" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="취소" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0" Click="FileDialogCancel_Click" />
                        <ui:Button Content="저장" Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                   Click="FileDialogSave_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Preview Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="PreviewDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="PreviewDialogOverlay_Click">
            <Border Width="600" MaxHeight="500" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock x:Name="PreviewTitle" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button Content="닫기" DockPanel.Dock="Right" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" HorizontalAlignment="Right" Padding="8,4"
                                   Click="PreviewClose_Click" />
                    </DockPanel>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="PreviewContentText" FontSize="12"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   TextWrapping="Wrap" Opacity="0.85" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Border>
    </Grid>
    </Grid>
</UserControl>
