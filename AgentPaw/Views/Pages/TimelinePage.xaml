<UserControl x:Class="AgentPaw.Views.Pages.TimelinePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:AgentPaw.Models"
             xmlns:vm="clr-namespace:AgentPaw.ViewModels"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Paper grain + Paw print -->
        <Border Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
        <Border Grid.Row="0" Grid.RowSpan="2" Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

        <!-- Tab bar + New Snapshot -->
        <Border Grid.Row="0" Padding="16,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PawBorder}"
                Background="{DynamicResource PawCreamBrush}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="EventsTabBtn"
                               Content="이벤트"
                               Icon="{ui:SymbolIcon History24}"
                               Appearance="Primary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="12,6" FontSize="12"
                               Margin="0,0,4,0"
                               Click="EventsTab_Click" />
                    <ui:Button x:Name="SnapshotsTabBtn"
                               Content="스냅샷"
                               Icon="{ui:SymbolIcon Save24}"
                               Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="12,6" FontSize="12"
                               Click="SnapshotsTab_Click" />
                </StackPanel>

                <ui:Button DockPanel.Dock="Right"
                           Content="스냅샷 생성"
                           Icon="{ui:SymbolIcon Add24}"
                           Appearance="Primary"
                           FontFamily="{StaticResource PawFont}"
                           HorizontalAlignment="Right"
                           ToolTip="현재 상태를 스냅샷으로 저장한다"
                           Click="CreateSnapshot_Click" />
            </DockPanel>
        </Border>

        <!-- Events List -->
        <ScrollViewer Grid.Row="1" Padding="16"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEventsTab, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel>
                <!-- Empty state with mascot -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,60,0,0"
                            Visibility="{Binding Events.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                    <Border Width="80" Height="80" CornerRadius="40"
                            HorizontalAlignment="Center" Margin="0,0,0,12"
                            Background="{DynamicResource PawCreamBrush}"
                            BorderBrush="{DynamicResource PawBorder}"
                            BorderThickness="2">
                        <TextBlock Text="&#x1F43E;" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.6" />
                    </Border>
                    <TextBlock Text="아직 이벤트가 없다"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="채팅을 시작하면 여기에 기록이 쌓인다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Events}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:TimelineEvent}">
                            <Border Margin="0,0,0,6" Padding="12,10"
                                    CornerRadius="8"
                                    Background="{DynamicResource PawCardBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource PawBorder}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Event type badge -->
                                    <Border Grid.Column="0"
                                            CornerRadius="4"
                                            Padding="8,3"
                                            Margin="0,0,12,0"
                                            VerticalAlignment="Top"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource PawPlanningBlue}"
                                            Background="{DynamicResource PawCreamBrush}">
                                        <TextBlock Text="{Binding EventType}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawPlanningBlue}" />
                                    </Border>

                                    <!-- Summary -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Summary}"
                                               TextWrapping="Wrap"
                                               FontSize="12"
                                               FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextPrimary}"
                                               VerticalAlignment="Center" />

                                    <!-- Timestamp -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding CreatedAt, StringFormat='{}{0:MM/dd HH:mm}'}"
                                               FontSize="10"
                                               FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}"
                                               Opacity="0.7"
                                               VerticalAlignment="Top"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Snapshots List -->
        <ScrollViewer Grid.Row="1" Padding="16"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsEventsTab, Converter={StaticResource InverseBoolToVisConverter}}">
            <StackPanel>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,60,0,0"
                            Visibility="{Binding Snapshots.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                    <Border Width="80" Height="80" CornerRadius="40"
                            HorizontalAlignment="Center" Margin="0,0,0,12"
                            Background="{DynamicResource PawCreamBrush}"
                            BorderBrush="{DynamicResource PawBorder}"
                            BorderThickness="2">
                        <TextBlock Text="&#x1F4BE;" FontSize="32"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Opacity="0.6" />
                    </Border>
                    <TextBlock Text="스냅샷이 없다"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="상단 버튼으로 현재 상태를 스냅샷으로 저장한다."
                               FontSize="11" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Snapshots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Snapshot}">
                            <Border Margin="0,0,0,6" Padding="14,12"
                                    CornerRadius="8"
                                    Background="{DynamicResource PawCardBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource PawBorder}">
                                <DockPanel>
                                    <!-- Rollback button -->
                                    <ui:Button DockPanel.Dock="Right"
                                               Content="복원"
                                               Icon="{ui:SymbolIcon ArrowUndo24}"
                                               Appearance="Caution"
                                               FontFamily="{StaticResource PawFont}"
                                               Padding="10,4"
                                               FontSize="11"
                                               VerticalAlignment="Center"
                                               ToolTip="이 스냅샷 시점으로 롤백한다"
                                               Tag="{Binding}"
                                               Click="Rollback_Click" />

                                    <StackPanel>
                                        <!-- Description -->
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding Path="Description" FallbackValue="" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <!-- Trigger type badge -->
                                            <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource PawGold}"
                                                    Background="{DynamicResource PawCreamBrush}">
                                                <TextBlock Text="{Binding TriggerType}"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawGold}" />
                                            </Border>
                                            <!-- Commit hash -->
                                            <TextBlock FontSize="10"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       Opacity="0.7"
                                                       VerticalAlignment="Center">
                                                <Run Text="{Binding GitCommitHash, StringFormat='{}{0}'}" />
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Timestamp -->
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}"
                                                   Opacity="0.6" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing Width="40" Height="40"
                             Foreground="{DynamicResource PawGold}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
        </Border>

        <!-- Error message -->
        <Border Grid.Row="1" VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Margin="16,8" Padding="12,10"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{DynamicResource PawErrorRed}"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                               Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           TextWrapping="Wrap" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Create Snapshot Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="20"
                Background="#88A09080"
                Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                MouseLeftButtonDown="DialogOverlay_Click">
            <Border MaxWidth="450"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="28,24"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}"
                    BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="스냅샷 생성" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,16" />

                    <TextBlock Text="설명 (선택)" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,6" />
                    <ui:TextBox x:Name="SnapshotDescInput"
                                Text="{Binding NewSnapshotDescription, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="예: v1.2 기능 추가 전 백업"
                                FontFamily="{StaticResource PawFont}"
                                MaxLength="200" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <ui:Button Content="취소" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="CloseCreateDialog_Click" />
                        <ui:Button Content="생성" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="SaveSnapshot_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Rollback Confirmation Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="20"
                Background="#88A09080"
                Visibility="{Binding IsRollbackDialogOpen, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                MouseLeftButtonDown="DialogOverlay_Click">
            <Border MaxWidth="500"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="28,24"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}"
                    BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="롤백 확인" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawImplOrange}" Margin="0,0,0,16" />

                    <TextBlock Text="이 스냅샷으로 복원하시겠습니까?"
                               FontSize="13"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               Margin="0,0,0,12" />

                    <!-- Impact summary -->
                    <Border Padding="12,10" CornerRadius="6"
                            Background="{DynamicResource PawCreamBrush}"
                            BorderBrush="{DynamicResource PawBorder}"
                            BorderThickness="1"
                            Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock FontSize="12"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}">
                                <Run Text="영향받는 이벤트: " Foreground="{DynamicResource PawPlanningBlue}" />
                                <Run Text="{Binding RollbackImpact.AffectedEvents, FallbackValue=0}"
                                     FontWeight="Bold" />
                                <Run Text="건" />
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <CheckBox x:Name="BackupCheckBox"
                              Content="현재 상태 백업 (권장)"
                              FontFamily="{StaticResource PawFont}"
                              IsChecked="{Binding RollbackBackup}"
                              Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="취소" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}" Margin="0,0,8,0"
                                   Click="CloseRollbackDialog_Click" />
                        <ui:Button Content="롤백 실행" Appearance="Danger"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="ExecuteRollback_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
