<UserControl x:Class="AgentPaw.Views.Pages.PersonaPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:controls="clr-namespace:AgentPaw.Views.Controls"
             Loaded="PersonaPage_Loaded"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F43E;" FontSize="16" Margin="0,0,6,0"
                               VerticalAlignment="Center" Opacity="0.6" />
                    <TextBlock Text="페르소나" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" />
                </StackPanel>
                <TextBlock Text="그룹별로 페르소나를 구성한다. 그룹 아래 기획, 디자인, 개발, QA 등 역할을 추가한다."
                           FontSize="10" FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}" Margin="22,2,0,0" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="0" Padding="10,8" CornerRadius="8" BorderThickness="1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center" />
                <TextBlock x:Name="ErrorText"
                           Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           VerticalAlignment="Center"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Scope selector: 글로벌 프리셋 / 프로젝트별 -->
                <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                    <DockPanel>
                        <TextBlock Text="적용 범위" FontSize="13" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                        <ComboBox x:Name="ScopeCombo"
                                  FontFamily="{StaticResource PawFont}"
                                  MinWidth="300"
                                  SelectionChanged="ScopeCombo_SelectionChanged" />
                    </DockPanel>
                </Border>

                <!-- Action bar -->
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="그룹 · 페르소나" FontSize="16" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               VerticalAlignment="Center" />
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <ui:Button x:Name="ReseedTemplatesBtn" Content="기본 템플릿 다시 불러오기"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   Padding="8,4" Margin="0,0,8,0"
                                   Visibility="Collapsed"
                                   ToolTip="빌트인 전역 페르소나를 삭제하고 최신 템플릿으로 다시 시드한다"
                                   Click="ReseedTemplates_Click" />
                        <ui:Button Content="그룹 추가" Icon="{ui:SymbolIcon FolderAdd24}"
                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   Padding="8,4" Margin="0,0,8,0"
                                   Click="CreateGroup_Click" />
                        <ui:Button Content="페르소나 추가" Icon="{ui:SymbolIcon PersonAdd24}"
                                   Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                   Padding="8,4"
                                   Click="CreatePersonaUngrouped_Click" />
                    </StackPanel>
                </DockPanel>

                <!-- Groups (Pinterest/Masonry 2-column layout) -->
                <ItemsControl x:Name="GroupsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <controls:MasonryPanel Columns="2" ColumnSpacing="12" RowSpacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PawCardStyle}">
                                <StackPanel>
                                    <!-- Group header -->
                                    <DockPanel Margin="0,0,0,6">
                                        <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center" MaxWidth="200">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x1F4C1;" FontSize="13" Margin="0,0,5,0"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextPrimary}"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="10"
                                                       FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       Margin="18,1,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <ui:Button Icon="{ui:SymbolIcon PersonAdd24}" Appearance="Transparent"
                                                       ToolTip="이 그룹에 페르소나 추가"
                                                       Padding="3" Click="CreatePersonaInGroup_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon Edit24}" Appearance="Transparent"
                                                       Padding="3" ToolTip="그룹 이름 변경"
                                                       Click="EditGroup_Click" Tag="{Binding}" />
                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                       Padding="3" ToolTip="그룹 삭제"
                                                       Click="DeleteGroup_Click" Tag="{Binding}" />
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Personas in this group -->
                                    <ItemsControl ItemsSource="{Binding Personas}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="8,7" Margin="0,0,0,4"
                                                        Background="{DynamicResource PawCreamBrush}"
                                                        BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                                    <DockPanel>
                                                        <!-- Avatar -->
                                                        <Grid DockPanel.Dock="Left" Width="60" Height="60"
                                                              Margin="0,0,8,0" VerticalAlignment="Center">
                                                            <Border CornerRadius="0" Width="60" Height="60"
                                                                    Background="{DynamicResource PawCreamBrush}"
                                                                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                                    Visibility="{Binding Avatar, Converter={StaticResource EmptyToVisibleConverter}}">
                                                                <TextBlock Text="&#x1F43E;" FontSize="24"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                            <Border CornerRadius="0" Width="60" Height="60"
                                                                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                                    Visibility="{Binding Avatar, Converter={StaticResource NotEmptyToVisibleConverter}}">
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding Avatar, Converter={StaticResource AvatarToImageConverter}}"
                                                                                Stretch="UniformToFill" />
                                                                </Border.Background>
                                                            </Border>
                                                        </Grid>
                                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                                                            <ui:Button Icon="{ui:SymbolIcon Edit24}" Appearance="Transparent"
                                                                       Padding="2" ToolTip="페르소나 편집"
                                                                       Click="EditPersona_Click" Tag="{Binding}" />
                                                            <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                                       Padding="2" ToolTip="페르소나 삭제"
                                                                       Click="DeletePersona_Click" Tag="{Binding}" />
                                                        </StackPanel>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                                                           FontFamily="{StaticResource PawFont}"
                                                                           Foreground="{DynamicResource PawTextPrimary}" />
                                                                <Border Background="{DynamicResource PawGoldTint}" CornerRadius="3" Padding="3,0"
                                                                        Margin="6,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding PrimaryModel}" FontSize="8"
                                                                               FontFamily="{StaticResource PawFont}"
                                                                               Foreground="{DynamicResource PawGold}" />
                                                                </Border>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" FontSize="9"
                                                                       FontFamily="{StaticResource PawFont}"
                                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                                       Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Empty group message -->
                                    <TextBlock Text="페르소나 없음"
                                               FontSize="10" FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,4,0,2"
                                               Visibility="{Binding Personas.Count, Converter={StaticResource ZeroToVisibleConverter}, FallbackValue=Collapsed}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Ungrouped personas -->
                <Border x:Name="UngroupedSection" Style="{StaticResource PawCardStyle}" Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F4CB;" FontSize="13" Margin="0,0,5,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="미분류" FontSize="14" FontWeight="SemiBold"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextSecondary}" />
                            </StackPanel>
                        </DockPanel>

                        <ItemsControl x:Name="UngroupedList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="6" Padding="8,7" Margin="0,0,0,4"
                                            Background="{DynamicResource PawCreamBrush}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1">
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Left" Width="60" Height="60"
                                                  Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border CornerRadius="0" Width="60" Height="60"
                                                        Background="{DynamicResource PawCreamBrush}"
                                                        BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                        Visibility="{Binding Avatar, Converter={StaticResource EmptyToVisibleConverter}}">
                                                    <TextBlock Text="&#x1F43E;" FontSize="24"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <Border CornerRadius="0" Width="60" Height="60"
                                                        BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                        Visibility="{Binding Avatar, Converter={StaticResource NotEmptyToVisibleConverter}}">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{Binding Avatar, Converter={StaticResource AvatarToImageConverter}}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>
                                            </Grid>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <ui:Button Icon="{ui:SymbolIcon Edit24}" Appearance="Transparent"
                                                           Padding="2" ToolTip="페르소나 편집"
                                                           Click="EditPersona_Click" Tag="{Binding}" />
                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent"
                                                           Padding="2" ToolTip="페르소나 삭제"
                                                           Click="DeletePersona_Click" Tag="{Binding}" />
                                            </StackPanel>
                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}" />
                                                    <Border Background="{DynamicResource PawGoldTint}" CornerRadius="3" Padding="3,0"
                                                            Margin="6,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding PrimaryModel}" FontSize="8"
                                                                   FontFamily="{StaticResource PawFont}"
                                                                   Foreground="{DynamicResource PawGold}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" FontSize="9"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawTextSecondary}"
                                                           Margin="0,1,0,0" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Empty state -->
                <TextBlock x:Name="NoPersonasText"
                           Text="그룹을 만들고 페르소나를 추가하세요."
                           FontSize="12" FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}" Margin="0,8,0,0"
                           HorizontalAlignment="Center" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <!-- Loading -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <ui:ProgressRing Width="40" Height="40"
                             Foreground="{DynamicResource PawGold}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>

        <!-- Group Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="GroupDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="GroupDialogOverlay_Click">
            <Border Width="420" CornerRadius="12" Padding="28,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock x:Name="GroupDialogTitle" Text="새 그룹"
                               FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="0,0,0,16" />

                    <TextBlock Text="그룹명" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="GroupNameInput" PlaceholderText="소프트웨어 개발"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                    <TextBlock Text="설명" FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="GroupDescInput" PlaceholderText="소프트웨어 개발 프로세스에 참여하는 역할군"
                                FontFamily="{StaticResource PawFont}" Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="취소" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0" Click="GroupDialogCancel_Click" />
                        <ui:Button Content="저장" Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                   Click="GroupDialogSave_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Persona Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="PersonaDialogOverlay"
                Panel.ZIndex="20"
                Background="#88A09080" Visibility="Collapsed"
                MouseLeftButtonDown="PersonaDialogOverlay_Click">
            <Border Width="560" MaxHeight="700" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.12" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Dialog title (pinned top) -->
                    <TextBlock Grid.Row="0" x:Name="PersonaDialogTitle" Text="새 페르소나"
                               FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}" Margin="28,24,28,16" />

                    <!-- Scrollable content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,0">
                        <StackPanel>
                            <!-- Avatar picker -->
                            <StackPanel Margin="0,0,0,16" HorizontalAlignment="Center">
                                <Grid Width="200" Height="200">
                                    <Border CornerRadius="0" Width="200" Height="200"
                                            Background="{DynamicResource PawCreamBrush}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                            x:Name="AvatarFallback">
                                        <TextBlock Text="&#x1F43E;" FontSize="72"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <Border CornerRadius="0" Width="200" Height="200"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                            x:Name="AvatarPreviewBorder" Visibility="Collapsed">
                                        <Border.Background>
                                            <ImageBrush x:Name="AvatarPreviewBrush" Stretch="UniformToFill" />
                                        </Border.Background>
                                    </Border>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <ui:Button Content="이미지 업로드" Icon="{ui:SymbolIcon Image24}"
                                               Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                               Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                               Click="ChooseAvatar_Click" />
                                    <ui:Button Content="이미지 선택" Icon="{ui:SymbolIcon AppsList24}"
                                               Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                               Padding="10,4" FontSize="11"
                                               Click="OpenTemplateDialog_Click" />
                                </StackPanel>
                                <ui:Button Content="제거" Appearance="Transparent"
                                           FontFamily="{StaticResource PawFont}"
                                           Padding="8,2" FontSize="10" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource PawTextSecondary}"
                                           x:Name="RemoveAvatarBtn" Visibility="Collapsed"
                                           Click="RemoveAvatar_Click" />
                            </StackPanel>

                            <!-- Group selector -->
                            <TextBlock Text="소속 그룹" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ComboBox x:Name="PersonaGroupCombo"
                                      DisplayMemberPath="Name"
                                      FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                            <TextBlock Text="이름 (코드)" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaNameInput" PlaceholderText="planner"
                                        FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                            <TextBlock Text="표시 이름" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaLabelInput" PlaceholderText="기획"
                                        FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                            <TextBlock Text="설명" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaDescInput" PlaceholderText="예: 기술 아키텍처를 설계한다"
                                        FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                            <TextBlock Text="시스템 프롬프트" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaPromptInput" AcceptsReturn="True" MinHeight="80"
                                        FontFamily="{StaticResource PawFont}" TextWrapping="Wrap" Margin="0,0,0,10" />

                            <TextBlock Text="지침 (Instructions)" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <TextBlock Text="이 페르소나가 응답할 때 따를 규칙, 참고 자료, 스타일 가이드"
                                       FontSize="10" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaInstructionsInput" AcceptsReturn="True" MinHeight="80"
                                        PlaceholderText="예: 한국어로 답변한다. 코드 블록에 파일 경로를 명시한다."
                                        FontFamily="{StaticResource PawFont}" TextWrapping="Wrap" Margin="0,0,0,10" />

                            <TextBlock Text="키워드 (쉼표로 구분)" FontSize="12" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                            <ui:TextBox x:Name="PersonaKeywordsInput" PlaceholderText="기획,설계,정책"
                                        FontFamily="{StaticResource PawFont}" Margin="0,0,0,10" />

                            <!-- Linked Instructions (편집 모드에서만 노출) -->
                            <StackPanel x:Name="PersonaLinkedInstructionsSection" Visibility="Collapsed" Margin="0,4,0,10">
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="연결된 지침"
                                                   FontSize="12" FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}" />
                                        <TextBlock Text="이 페르소나에만 적용되는 지침 파일. 프로젝트 지침(1순위) 뒤에 덧붙여진다."
                                                   FontSize="10" FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="연결 추가"
                                               Icon="{ui:SymbolIcon Link24}"
                                               Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                               Padding="10,4" FontSize="11"
                                               Click="OpenPersonaInstructionLink_Click" />
                                </Grid>
                                <ItemsControl x:Name="PersonaLinkedInstructionsList"
                                              ItemsSource="{Binding PersonaLinkedInstructions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource PawCreamBrush}"
                                                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                    CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:SymbolIcon Grid.Column="0" Symbol="Document24" FontSize="14"
                                                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                                                   Foreground="{DynamicResource PawTextSecondary}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                               FontSize="12" FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <ui:Button Grid.Column="2" Content="해제"
                                                               Appearance="Transparent" FontFamily="{StaticResource PawFont}"
                                                               Padding="6,2" FontSize="10"
                                                               Foreground="{DynamicResource PawTextSecondary}"
                                                               Tag="{Binding}"
                                                               Click="UnlinkPersonaInstruction_Click" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock x:Name="NoPersonaInstructionsText" Text="연결된 지침 없음"
                                           FontSize="11" FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextSecondary}" Opacity="0.6"
                                           HorizontalAlignment="Center" Margin="0,8,0,4"
                                           Visibility="Collapsed" />
                            </StackPanel>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="주 모델" FontSize="12" FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="PersonaModelCombo"
                                              FontFamily="{StaticResource PawFont}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="대체 모델" FontSize="12" FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                                    <ComboBox x:Name="PersonaFallbackCombo"
                                              FontFamily="{StaticResource PawFont}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Temperature" FontSize="12" FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PersonaTempInput" Text="0.7" FontFamily="{StaticResource PawFont}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="최대 토큰" FontSize="12" FontFamily="{StaticResource PawFont}"
                                               Foreground="{DynamicResource PawTextSecondary}" Margin="0,0,0,4" />
                                    <ui:TextBox x:Name="PersonaTokensInput" Text="4096" FontFamily="{StaticResource PawFont}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Buttons pinned to bottom -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource PawBorder}" BorderThickness="0,1,0,0"
                            Padding="28,16,28,20">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="취소" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                       Margin="0,0,8,0" Click="PersonaDialogCancel_Click" />
                            <ui:Button Content="저장" Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                       Click="PersonaDialogSave_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Template Picker Dialog (popup-in-popup) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="TemplateDialogOverlay"
                Panel.ZIndex="30"
                Background="#A0A09080" Visibility="Collapsed"
                MouseLeftButtonDown="TemplateDialogOverlay_Click">
            <Border Width="640" MaxHeight="600" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.18" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="24,20,24,12">
                        <TextBlock DockPanel.Dock="Left" Text="캐릭터 템플릿"
                                   FontSize="16" FontWeight="Bold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}" />
                        <TextBlock Text="28종 강아지 협업자 중 선택한다"
                                   FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Bottom" Margin="10,0,0,2" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0">
                        <ItemsControl x:Name="AvatarTemplateGallery">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="92" Height="118" Margin="4" Padding="6"
                                            CornerRadius="8" Background="{DynamicResource PawCreamBrush}"
                                            BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonDown="AvatarTemplate_Click">
                                        <StackPanel>
                                            <Border CornerRadius="0" Width="78" Height="78"
                                                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                    HorizontalAlignment="Center">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding DataUri, Converter={StaticResource AvatarToImageConverter}}"
                                                                Stretch="UniformToFill" />
                                                </Border.Background>
                                            </Border>
                                            <TextBlock Text="{Binding BreedName}"
                                                       FontSize="10" FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextPrimary}"
                                                       HorizontalAlignment="Center" Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding RoleHint}"
                                                       FontSize="8" FontFamily="{StaticResource PawFont}"
                                                       Foreground="{DynamicResource PawTextSecondary}"
                                                       HorizontalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource PawBorder}" BorderThickness="0,1,0,0"
                            Padding="24,14,24,18">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="닫기" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                       Click="CloseTemplateDialog_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Persona-Instruction Link Picker (popup-in-popup) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="PersonaInstructionLinkOverlay"
                Panel.ZIndex="30"
                Background="#A0A09080" Visibility="Collapsed"
                MouseLeftButtonDown="PersonaInstructionLinkOverlay_Click">
            <Border Width="560" MaxHeight="600" CornerRadius="12"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PawCardBg}"
                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                    MouseLeftButtonDown="DialogContent_Click">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Opacity="0.18" ShadowDepth="4" Color="#8B7355" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="24,20,24,12">
                        <TextBlock DockPanel.Dock="Left" Text="지침 연결"
                                   FontSize="16" FontWeight="Bold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}" />
                        <TextBlock Text="이 페르소나에 연결할 지침 파일을 선택한다"
                                   FontSize="11" FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   VerticalAlignment="Bottom" Margin="10,0,0,2" />
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding PersonaAvailableInstructionGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                CornerRadius="6" Padding="8" Margin="0,0,0,8"
                                                Background="{DynamicResource PawCardBg}">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}"
                                                               FontSize="12" FontWeight="Bold"
                                                               FontFamily="{StaticResource PawFont}"
                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                               VerticalAlignment="Center" />
                                                    <ui:Button Grid.Column="1" Content="그룹 전체 연결"
                                                               Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                                               Padding="8,2" FontSize="10"
                                                               Tag="{Binding}"
                                                               Click="LinkPersonaInstructionGroup_Click" />
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding Files}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource PawCreamBrush}"
                                                                    BorderBrush="{DynamicResource PawBorder}" BorderThickness="1"
                                                                    CornerRadius="4" Padding="8,4" Margin="0,0,0,4">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <ui:SymbolIcon Grid.Column="0" Symbol="Document24" FontSize="14"
                                                                                   VerticalAlignment="Center" Margin="0,0,6,0"
                                                                                   Foreground="{DynamicResource PawTextSecondary}" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                               FontSize="12" FontFamily="{StaticResource PawFont}"
                                                                               Foreground="{DynamicResource PawTextPrimary}"
                                                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                                    <ui:Button Grid.Column="2" Content="연결"
                                                                               Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                                                               Padding="8,2" FontSize="10"
                                                                               Tag="{Binding}"
                                                                               Click="LinkPersonaInstruction_Click" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock x:Name="NoAvailableInstructionsText"
                                       Text="연결 가능한 지침 파일이 없다. 먼저 지침 관리 화면에서 파일을 추가한다."
                                       FontSize="11" FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,16,0,16"
                                       Visibility="Collapsed" />
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" BorderBrush="{DynamicResource PawBorder}" BorderThickness="0,1,0,0"
                            Padding="24,14,24,18">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ui:Button Content="닫기" Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                       Click="ClosePersonaInstructionLink_Click" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Border>
    </Grid>
    </Grid>
</UserControl>
