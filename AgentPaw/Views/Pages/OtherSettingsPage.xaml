<UserControl x:Class="AgentPaw.Views.Pages.OtherSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             Loaded="OtherSettingsPage_Loaded">

    <Grid>
    <!-- Paper grain + Paw print -->
    <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
    <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24" MaxWidth="800">

            <!-- Header -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                <TextBlock Text="&#x1F43E;" FontSize="20" Margin="0,0,8,0"
                           VerticalAlignment="Center" Opacity="0.6" />
                <TextBlock Text="설정"
                           FontSize="24" FontWeight="Bold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}" />
            </StackPanel>

            <!-- Messages -->
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=ErrorText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24" Foreground="{DynamicResource PawErrorRed}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource PawErrorRed}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>
            <Border Padding="12,10" CornerRadius="8" BorderThickness="1" Margin="0,0,0,8"
                    Visibility="{Binding ElementName=SuccessText, Path=Visibility}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.1" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" Foreground="{DynamicResource PawSystemGreen}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock x:Name="SuccessText"
                               Foreground="{DynamicResource PawSystemGreen}" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <!-- App Info -->
            <Border Style="{StaticResource PawCardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="앱 정보" FontSize="16" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextPrimary}" />
                        <ui:Button DockPanel.Dock="Right" Content="업데이트 확인"
                                   Appearance="Secondary" FontFamily="{StaticResource PawFont}"
                                   HorizontalAlignment="Right" Padding="10,4"
                                   Click="CheckForUpdate_Click"
                                   IsEnabled="{Binding IsCheckingUpdate, Converter={StaticResource InverseBoolConverter}}" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <TextBlock Text="Agent Paw v" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                        <TextBlock Text="{Binding CurrentVersion}" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                        <TextBlock Text=" (WPF)" FontSize="12"
                                   FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" />
                    </StackPanel>
                    <TextBlock Text=".NET 10 + CommunityToolkit.Mvvm + WPF-UI" FontSize="11"
                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}" Opacity="0.7"
                               Margin="0,2,0,0" />

                    <!-- Update Available Banner -->
                    <Border Margin="0,12,0,0" Padding="12,10" CornerRadius="8" BorderThickness="1"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisConverter}}">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.08" />
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" Opacity="0.35" />
                        </Border.BorderBrush>
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowDownload24" Foreground="{DynamicResource PawSystemGreen}"
                                                   FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center" />
                                    <TextBlock Text="새 버전 v" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding LatestVersion}" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text=" 사용 가능" FontSize="13" FontWeight="SemiBold"
                                               FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawSystemGreen}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <ui:Button DockPanel.Dock="Right" Content="지금 설치"
                                           Appearance="Primary" FontFamily="{StaticResource PawFont}"
                                           HorizontalAlignment="Right" Padding="10,4"
                                           Click="InstallUpdate_Click"
                                           IsEnabled="{Binding IsDownloadingUpdate, Converter={StaticResource InverseBoolConverter}}" />
                            </DockPanel>
                            <TextBlock Text="{Binding UpdateReleaseNotes}" FontSize="11"
                                       FontFamily="{StaticResource PawFont}" Foreground="{DynamicResource PawTextSecondary}"
                                       TextWrapping="Wrap" />
                            <ProgressBar Height="6" Margin="0,8,0,0"
                                         Value="{Binding UpdateDownloadProgress}" Maximum="100"
                                         Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BoolToVisConverter}}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
    </Grid>
</UserControl>
