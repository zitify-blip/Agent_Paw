<UserControl x:Class="AgentPaw.Views.Pages.WikiPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:models="clr-namespace:AgentPaw.Models"
             xmlns:vm="clr-namespace:AgentPaw.ViewModels"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Paper grain + paw print background -->
        <Border Grid.Row="1" Background="{StaticResource PaperGrainBrush}"
                IsHitTestVisible="False" />
        <Border Grid.Row="1" Background="{StaticResource PawPrintTileBrush}"
                IsHitTestVisible="False" />

        <!-- Top bar: Search + Category filters + New -->
        <Border Grid.Row="0" Padding="16,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource PawBorder}"
                Background="{DynamicResource PawCardBg}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="새 위키"
                           Icon="{ui:SymbolIcon Add24}"
                           Appearance="Primary"
                           FontFamily="{StaticResource PawFont}"
                           HorizontalAlignment="Right"
                           ToolTip="새 위키 문서 작성"
                           Click="CreateWiki_Click" />

                <StackPanel Orientation="Horizontal">
                    <ui:TextBox x:Name="SearchInput"
                                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="검색..."
                                FontFamily="{StaticResource PawFont}"
                                Width="200"
                                Margin="0,0,8,0"
                                KeyDown="SearchInput_KeyDown" />

                    <ui:Button x:Name="AllFilterBtn"
                               Content="{Binding AllCount, StringFormat='전체 ({0})'}"
                               Appearance="Primary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="8,4" FontSize="11" Margin="0,0,3,0"
                               Click="FilterAll_Click" />
                    <ui:Button x:Name="AdrFilterBtn"
                               Content="{Binding AdrCount, StringFormat='ADR ({0})'}"
                               Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="8,4" FontSize="11" Margin="0,0,3,0"
                               Click="FilterAdr_Click" />
                    <ui:Button x:Name="SpecFilterBtn"
                               Content="{Binding SpecCount, StringFormat='SPEC ({0})'}"
                               Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="8,4" FontSize="11" Margin="0,0,3,0"
                               Click="FilterSpec_Click" />
                    <ui:Button x:Name="TroubleFilterBtn"
                               Content="{Binding TroubleCount, StringFormat='TROUBLE ({0})'}"
                               Appearance="Secondary"
                               FontFamily="{StaticResource PawFont}"
                               Padding="8,4" FontSize="11"
                               Click="FilterTrouble_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Wiki List View -->
        <ScrollViewer Grid.Row="1" Padding="16"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsDetailView, Converter={StaticResource InverseBoolToVisConverter}}">
            <StackPanel>
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,60,0,0"
                            Visibility="{Binding Wikis.Count, Converter={StaticResource ZeroToVisibleConverter}}">
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{DynamicResource PawCreamBrush}"
                            BorderThickness="2"
                            BorderBrush="{DynamicResource PawBorder}"
                            HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F4D6;" FontSize="36"
                                   Opacity="0.6"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="위키 문서가 없다"
                               FontSize="14" FontWeight="SemiBold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextPrimary}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="ADR·SPEC·TROUBLE 문서를 작성하여 지식을 축적한다."
                               FontSize="11"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>

                <ItemsControl ItemsSource="{Binding Wikis}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:WikiDocument}">
                            <Border Margin="0,0,0,8" Padding="14,12"
                                    CornerRadius="8"
                                    Background="{DynamicResource PawCardBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource PawBorder}"
                                    Cursor="Hand"
                                    Tag="{Binding}"
                                    MouseLeftButtonDown="WikiItem_Click">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding UpdatedAt, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}"
                                                   Opacity="0.7"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextSecondary}"
                                                   Opacity="0.6"
                                                   HorizontalAlignment="Right" Margin="0,3,0,0" />
                                    </StackPanel>

                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                                    Background="{DynamicResource PawCreamBrush}"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource PawGold}">
                                                <TextBlock Text="{Binding Category}"
                                                           FontSize="10"
                                                           FontFamily="{StaticResource PawFont}"
                                                           Foreground="{DynamicResource PawGold}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawTextPrimary}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Wiki Detail View -->
        <Grid Grid.Row="1" Margin="24,16"
              Visibility="{Binding IsDetailView, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Detail header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <DockPanel>
                    <ui:Button DockPanel.Dock="Left"
                               Icon="{ui:SymbolIcon ArrowLeft24}"
                               Appearance="Transparent"
                               ToolTip="목록으로"
                               Click="BackToList_Click"
                               Margin="0,0,12,0" />

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <!-- 읽기 모드 버튼 -->
                        <ui:Button Content="편집"
                                   Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Padding="10,4"
                                   Click="StartEdit_Click"
                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                        <!-- 편집 모드 버튼 -->
                        <ui:Button Content="취소" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Padding="10,4" Margin="0,0,6,0"
                                   Click="CancelEdit_Click"
                                   Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                        <ui:Button Content="저장" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Padding="10,4"
                                   Click="SaveEdit_Click"
                                   Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center">
                        <!-- 읽기 모드: 제목 표시 -->
                        <TextBlock Text="{Binding SelectedWiki.Title}"
                                   FontSize="18" FontWeight="Bold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                        <!-- 편집 모드: 제목 입력 -->
                        <ui:TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="16" MaxLength="200"
                                    FontFamily="{StaticResource PawFont}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />

                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <!-- 읽기 모드: 카테고리 뱃지 -->
                            <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                    Background="{DynamicResource PawCreamBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource PawGold}"
                                    Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}">
                                <TextBlock Text="{Binding SelectedWiki.Category}"
                                           FontSize="10"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawGold}" />
                            </Border>
                            <!-- 편집 모드: 카테고리 콤보 -->
                            <ComboBox SelectedValue="{Binding EditCategory}"
                                      SelectedValuePath="Tag"
                                      FontFamily="{StaticResource PawFont}"
                                      Width="160"
                                      Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                                <ComboBoxItem Content="ADR" Tag="WIKI_ADR" />
                                <ComboBoxItem Content="SPEC" Tag="WIKI_SPEC" />
                                <ComboBoxItem Content="TROUBLE" Tag="WIKI_TROUBLE" />
                            </ComboBox>

                            <TextBlock Text="{Binding SelectedWiki.Version, StringFormat='v{0}'}"
                                       FontSize="11"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                            <TextBlock Text="{Binding SelectedWiki.UpdatedAt, StringFormat='  수정: {0:yyyy-MM-dd HH:mm}'}"
                                       FontSize="11"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}"
                                       Opacity="0.8"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </StackPanel>

            <!-- Content area -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- 읽기 모드 -->
                    <TextBlock Text="{Binding SelectedWiki.Content}"
                               TextWrapping="Wrap" FontSize="13"
                               FontFamily="Cascadia Code, Consolas, Courier New"
                               Foreground="{DynamicResource PawTextPrimary}"
                               Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                    <!-- 편집 모드 -->
                    <TextBox Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             FontSize="13" FontFamily="Cascadia Code, Consolas, Courier New"
                             Background="{DynamicResource PawCreamBrush}"
                             Foreground="{DynamicResource PawTextPrimary}"
                             BorderBrush="{DynamicResource PawBorder}"
                             MinHeight="400"
                             Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="10"
                Background="#88F5F0E8"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ui:ProgressRing Width="40" Height="40"
                                 Foreground="{DynamicResource PawGold}" />
                <TextBlock Text="불러오는 중..."
                           FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           HorizontalAlignment="Center" Margin="0,12,0,0" />
            </StackPanel>
        </Border>

        <!-- Error message -->
        <Border Grid.Row="1" VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Margin="16,8" Padding="12,10"
                CornerRadius="8"
                BorderThickness="1"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
            <Border.Background>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
            </Border.BorderBrush>
            <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon Symbol="Warning24"
                               Foreground="{DynamicResource PawErrorRed}"
                               FontSize="16"
                               Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource PawErrorRed}"
                           FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Create Wiki Dialog -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                Panel.ZIndex="20"
                Background="#88A09080"
                Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                MouseLeftButtonDown="DialogOverlay_Click">
            <Border MaxWidth="550"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12"
                    Padding="28,24"
                    Background="{DynamicResource PawCardBg}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource PawBorder}"
                    MouseLeftButtonDown="DialogContent_Click">
                <StackPanel>
                    <TextBlock Text="새 위키 문서" FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawGold}" Margin="0,0,0,16" />

                    <TextBlock Text="카테고리" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="NewCategoryCombo"
                              SelectedValue="{Binding NewCategory}"
                              SelectedValuePath="Tag"
                              FontFamily="{StaticResource PawFont}"
                              Width="280" HorizontalAlignment="Left"
                              Margin="0,0,0,12">
                        <ComboBoxItem Content="ADR (Architecture Decision Record)" Tag="WIKI_ADR" IsSelected="True" />
                        <ComboBoxItem Content="SPEC (Specification)" Tag="WIKI_SPEC" />
                        <ComboBoxItem Content="TROUBLE (Troubleshooting)" Tag="WIKI_TROUBLE" />
                    </ComboBox>

                    <TextBlock Text="제목" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <ui:TextBox x:Name="NewTitleInput"
                                Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="예: RFC-001 인증 구조"
                                FontFamily="{StaticResource PawFont}"
                                MaxLength="200"
                                Margin="0,0,0,12" />

                    <TextBlock Text="내용 (Markdown)" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="200" MaxHeight="350"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12"
                             Background="{DynamicResource PawCreamBrush}"
                             Foreground="{DynamicResource PawTextPrimary}"
                             BorderBrush="{DynamicResource PawBorder}"
                             VerticalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <ui:Button Content="취소" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0"
                                   Click="CloseCreateDialog_Click" />
                        <ui:Button Content="생성" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="SaveWiki_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
