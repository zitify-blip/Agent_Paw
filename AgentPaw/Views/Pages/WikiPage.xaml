<UserControl x:Class="AgentPaw.Views.Pages.WikiPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:AgentPaw.ViewModels"
             Focusable="True"
             PreviewKeyDown="Page_PreviewKeyDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="180" MaxWidth="360" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════
             LEFT: Tree Panel
        ══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource PawBorder}"
                Background="{DynamicResource PawCardBg}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tree header -->
                <Border Grid.Row="0"
                        Padding="12,8"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource PawBorder}">
                    <DockPanel>
                        <ui:Button DockPanel.Dock="Right"
                                   Icon="{ui:SymbolIcon Add24}"
                                   Appearance="Transparent"
                                   Padding="6"
                                   ToolTip="새 루트 페이지 추가"
                                   Click="CreateRoot_Click" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,2,0">
                            <ui:ProgressRing Width="14" Height="14"
                                             Foreground="{DynamicResource PawGold}"
                                             VerticalAlignment="Center" Margin="0,0,2,0"
                                             Visibility="{Binding IsConsolidating, Converter={StaticResource BoolToVisConverter}}" />
                            <ui:Button Icon="{ui:SymbolIcon Sparkle24}"
                                       Appearance="Transparent"
                                       Padding="6"
                                       ToolTip="대화 내용을 위키로 정리하기"
                                       IsEnabled="{Binding IsConsolidating, Converter={StaticResource InverseBoolConverter}}"
                                       Click="ConsolidateWiki_Click" />
                        </StackPanel>
                        <TextBlock Text="위키"
                                   FontSize="13" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   VerticalAlignment="Center" />
                    </DockPanel>
                </Border>

                <!-- Search -->
                <Border Grid.Row="1" Padding="8,6">
                    <ui:TextBox x:Name="SearchInput"
                                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="검색..."
                                FontFamily="{StaticResource PawFont}"
                                FontSize="12"
                                KeyDown="SearchInput_KeyDown" />
                </Border>

                <!-- Tree list -->
                <Grid Grid.Row="2">
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="16"
                                Visibility="{Binding IsTreeEmpty, Converter={StaticResource BoolToVisConverter}}">
                        <TextBlock Text="&#x1F4D6;" FontSize="32"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" />
                        <TextBlock Text="위키 문서가 없다"
                                   FontSize="12" FontWeight="SemiBold"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="+ 버튼으로 첫 페이지를 추가한다."
                                   FontSize="10"
                                   FontFamily="{StaticResource PawFont}"
                                   Foreground="{DynamicResource PawTextSecondary}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Tree nodes -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding FlatNodes}"
                                      Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:WikiNode}">
                                    <Border x:Name="NodeBorder"
                                            MinHeight="28"
                                            Cursor="Hand"
                                            Tag="{Binding}"
                                            MouseLeftButtonDown="TreeNode_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.08" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.16" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <DockPanel Margin="{Binding Indent}">
                                            <!-- Chevron toggle (only when has children) -->
                                            <Button DockPanel.Dock="Left"
                                                    Width="16" Height="16"
                                                    Padding="0"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Tag="{Binding}"
                                                    Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisConverter}}"
                                                    Click="ChevronToggle_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center" />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <TextBlock FontSize="8"
                                                           Foreground="{DynamicResource PawTextSecondary}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▶" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                    <Setter Property="Text" Value="▼" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Button>
                                            <!-- Spacer when no children -->
                                            <Border DockPanel.Dock="Left" Width="16"
                                                    Visibility="{Binding HasChildren, Converter={StaticResource InverseBoolToVisConverter}}" />

                                            <!-- Page icon -->
                                            <TextBlock DockPanel.Dock="Left"
                                                       Text="&#x1F4C4;"
                                                       FontSize="10"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,4,0" />

                                            <!-- Title -->
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       FontFamily="{StaticResource PawFont}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PawTextPrimary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource PawGold}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════
             RIGHT: Content Panel
        ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <!-- Background textures -->
            <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
            <Border Background="{StaticResource PawPrintTileBrush}" IsHitTestVisible="False" />

            <!-- No selection: empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasSelectedNode, Converter={StaticResource InverseBoolToVisConverter}}">
                <Border Width="72" Height="72" CornerRadius="36"
                        Background="{DynamicResource PawCreamBrush}"
                        BorderThickness="2" BorderBrush="{DynamicResource PawBorder}"
                        HorizontalAlignment="Center" Margin="0,0,0,16">
                    <TextBlock Text="&#x1F4D6;" FontSize="30"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="페이지를 선택한다"
                           FontSize="14" FontWeight="SemiBold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="왼쪽 트리에서 문서를 선택하거나 새 페이지를 추가한다."
                           FontSize="11"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Has selection: document view -->
            <Grid Visibility="{Binding HasSelectedNode, Converter={StaticResource BoolToVisConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Document header -->
                <Border Grid.Row="0"
                        Padding="24,14,24,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource PawBorder}"
                        Background="{DynamicResource PawCardBg}">
                    <DockPanel>
                        <!-- Action buttons (right side) -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <!-- Read mode actions -->
                            <ui:Button Content="하위 페이지"
                                       Icon="{ui:SymbolIcon Add24}"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="8,4" FontSize="11" Margin="0,0,6,0"
                                       ToolTip="현재 페이지 아래에 하위 페이지를 추가한다"
                                       Click="CreateChild_Click"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                            <ui:Button Content="편집"
                                       Icon="{ui:SymbolIcon Edit24}"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="8,4" FontSize="11" Margin="0,0,6,0"
                                       Click="StartEdit_Click"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                            <ui:Button Content="삭제"
                                       Icon="{ui:SymbolIcon Delete24}"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawErrorRed}"
                                       Padding="8,4" FontSize="11"
                                       Click="DeleteNode_Click"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                            <!-- Edit mode actions -->
                            <ui:Button Content="취소"
                                       Appearance="Secondary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="8,4" FontSize="11" Margin="0,0,6,0"
                                       Click="CancelEdit_Click"
                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                            <ui:Button Content="저장"
                                       Appearance="Primary"
                                       FontFamily="{StaticResource PawFont}"
                                       Padding="8,4" FontSize="11"
                                       Click="SaveEdit_Click"
                                       Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                        </StackPanel>

                        <!-- Title area -->
                        <StackPanel VerticalAlignment="Center">
                            <!-- Read mode: title display -->
                            <TextBlock Text="{Binding SelectedNode.Title}"
                                       FontSize="17" FontWeight="Bold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextPrimary}"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                            <!-- Edit mode: title input -->
                            <ui:TextBox Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="15" MaxLength="200"
                                        FontFamily="{StaticResource PawFont}"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                            <!-- Meta info (read mode only) -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}">
                                <TextBlock Text="{Binding SelectedNode.Document.Version, StringFormat='v{0}'}"
                                           FontSize="10"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextSecondary}"
                                           Opacity="0.7"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SelectedNode.Document.UpdatedAt, StringFormat='  수정: {0:yyyy-MM-dd HH:mm}'}"
                                           FontSize="10"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextSecondary}"
                                           Opacity="0.7"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Document body -->
                <ScrollViewer Grid.Row="1"
                              Padding="24,20"
                              VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!-- Read mode -->
                        <TextBlock Text="{Binding SelectedNode.Document.Content}"
                                   TextWrapping="Wrap" FontSize="13"
                                   FontFamily="Cascadia Code, Consolas, Courier New"
                                   Foreground="{DynamicResource PawTextPrimary}"
                                   LineHeight="20"
                                   Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisConverter}}" />
                        <!-- Edit mode -->
                        <TextBox x:Name="EditContentBox"
                                 Text="{Binding EditContent, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="True"
                                 FontSize="13" FontFamily="Cascadia Code, Consolas, Courier New"
                                 Background="{DynamicResource PawCreamBrush}"
                                 Foreground="{DynamicResource PawTextPrimary}"
                                 BorderBrush="{DynamicResource PawBorder}"
                                 MinHeight="400"
                                 VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}" />
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Error banner -->
            <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                    Margin="16,8" Padding="12,10"
                    CornerRadius="8" BorderThickness="1"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}">
                <Border.Background>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.08" />
                </Border.Background>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{StaticResource PawErrorRedColor}" Opacity="0.35" />
                </Border.BorderBrush>
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Warning24"
                                   Foreground="{DynamicResource PawErrorRed}"
                                   FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{DynamicResource PawErrorRed}"
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               TextWrapping="Wrap" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Loading overlay -->
            <Border Panel.ZIndex="10"
                    Background="#88F5F0E8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ui:ProgressRing Width="40" Height="40" Foreground="{DynamicResource PawGold}" />
                    <TextBlock Text="불러오는 중..."
                               FontSize="12" FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             Consolidation progress overlay (full-grid)
        ══════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Panel.ZIndex="15"
                Background="#C0F5F0E8"
                Visibility="{Binding IsConsolidating, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="280">
                <!-- Icon -->
                <Border Width="56" Height="56" CornerRadius="28"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Border.Background>
                        <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.15" />
                    </Border.Background>
                    <ui:ProgressRing Width="32" Height="32"
                                     IsIndeterminate="True"
                                     Foreground="{DynamicResource PawGold}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                </Border>

                <!-- Title -->
                <TextBlock Text="위키 정리 중"
                           FontSize="15" FontWeight="SemiBold"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextPrimary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8" />

                <!-- Status text -->
                <TextBlock Text="{Binding ConsolidationStatus}"
                           FontSize="12"
                           FontFamily="{StaticResource PawFont}"
                           Foreground="{DynamicResource PawTextSecondary}"
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"
                           Margin="0,0,0,16" />

                <!-- Progress bar (indeterminate) -->
                <ProgressBar IsIndeterminate="True"
                             Height="3"
                             Foreground="{DynamicResource PawGold}"
                             Background="Transparent"
                             BorderThickness="0" />
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════
             Create Page Dialog (full-grid overlay)
        ══════════════════════════════════════════ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2"
                Panel.ZIndex="20"
                Background="#88A09080"
                Visibility="{Binding IsCreateDialogOpen, Converter={StaticResource BoolToVisConverter}, FallbackValue=Collapsed}"
                MouseLeftButtonDown="DialogOverlay_Click">
            <Border MaxWidth="550"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="28,24"
                    Background="{DynamicResource PawCardBg}"
                    BorderThickness="1" BorderBrush="{DynamicResource PawBorder}"
                    MouseLeftButtonDown="DialogContent_Click">
                <StackPanel>
                    <TextBlock Text="{Binding CreateDialogTitle}"
                               FontSize="18" FontWeight="Bold"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawGold}"
                               Margin="0,0,0,16" />

                    <TextBlock Text="제목" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <ui:TextBox x:Name="NewTitleInput"
                                Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="페이지 제목을 입력한다"
                                FontFamily="{StaticResource PawFont}"
                                MaxLength="200"
                                Margin="0,0,0,12" />

                    <TextBlock Text="내용 (Markdown, 선택)" FontSize="12"
                               FontFamily="{StaticResource PawFont}"
                               Foreground="{DynamicResource PawTextSecondary}"
                               Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewContent, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="120" MaxHeight="280"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12"
                             Background="{DynamicResource PawCreamBrush}"
                             Foreground="{DynamicResource PawTextPrimary}"
                             BorderBrush="{DynamicResource PawBorder}"
                             VerticalScrollBarVisibility="Auto" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <ui:Button Content="취소" Appearance="Secondary"
                                   FontFamily="{StaticResource PawFont}"
                                   Margin="0,0,8,0"
                                   Click="CloseCreateDialog_Click" />
                        <ui:Button Content="생성" Appearance="Primary"
                                   FontFamily="{StaticResource PawFont}"
                                   Click="SaveWiki_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
