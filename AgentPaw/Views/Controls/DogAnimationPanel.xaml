<UserControl x:Class="AgentPaw.Views.Controls.DogAnimationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="120">
    <Border BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource PawBorder}"
            Background="{DynamicResource PawDarkBg}">
        <!-- ClipToBounds=False: 말풍선이 패널 위로 살짝 올라오는 것을 허용 -->
        <Canvas x:Name="DogsCanvas" ClipToBounds="False" />
    </Border>
</UserControl>
