<ui:FluentWindow x:Class="AgentPaw.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:AgentPaw.Views.Pages"
        Title="Agent Paw"
        Icon="pack://application:,,,/Assets/app.ico"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">

    <Grid>
        <!-- Login Page (visible when not authenticated) -->
        <pages:LoginPage x:Name="LoginPageControl"
                         Visibility="Visible" />

        <!-- Main App Shell (visible when authenticated) -->
        <Grid x:Name="AppShell" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══════ Sidebar (Warm Brown + Dog-Themed) ═══════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PawSidebarBg}"
                    BorderThickness="0,0,1,0"
                    BorderBrush="{DynamicResource PawSidebarBorder}">
                <Grid>
                    <!-- Paw print background pattern -->
                    <Border Background="{StaticResource PawPrintSidebarBrush}" IsHitTestVisible="False" />

                    <DockPanel>
                        <!-- App Title with paw -->
                        <StackPanel DockPanel.Dock="Top" Margin="20,20,20,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F43E;" FontSize="24" Margin="0,0,8,0" />
                                <TextBlock Text="Agent Paw"
                                           FontSize="20" FontWeight="Bold"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawGold}" />
                            </StackPanel>
                            <TextBlock Text="Product Agentic Workflow"
                                       FontSize="10" Foreground="{DynamicResource PawSidebarMuted}" Margin="32,2,0,0"
                                       FontFamily="{StaticResource PawFont}" />
                        </StackPanel>

                        <!-- Gold separator with paw accent -->
                        <Grid DockPanel.Dock="Top" Height="1" Margin="16,0">
                            <Border Background="{DynamicResource PawSidebarBorder}" />
                            <Border Width="40" Height="3" CornerRadius="1.5"
                                    HorizontalAlignment="Center" Margin="0,-1,0,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00C8A96E" Offset="0" />
                                        <GradientStop Color="#C8A96E" Offset="0.5" />
                                        <GradientStop Color="#00C8A96E" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- Navigation -->
                        <StackPanel DockPanel.Dock="Top" Margin="10,12,10,0">
                            <!-- 대화 진행 중 배너 — 워크스페이스 외 페이지에서만 노출 -->
                            <Border x:Name="ChatInProgressBanner"
                                    Visibility="Collapsed"
                                    Margin="0,0,0,8"
                                    Padding="10,8"
                                    CornerRadius="8"
                                    Cursor="Hand"
                                    BorderThickness="1"
                                    MouseLeftButtonUp="ChatInProgressBanner_Click">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.15" />
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="{StaticResource PawGoldColor}" Opacity="0.45" />
                                </Border.BorderBrush>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:ProgressRing Width="14" Height="14"
                                                     IsIndeterminate="True"
                                                     Foreground="{DynamicResource PawGold}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,8,0" />
                                    <StackPanel>
                                        <TextBlock Text="응답 생성 중…"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawGold}" />
                                        <TextBlock x:Name="ChatInProgressProjectName"
                                                   FontSize="10"
                                                   FontFamily="{StaticResource PawFont}"
                                                   Foreground="{DynamicResource PawSidebarMuted}"
                                                   Margin="0,1,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <ui:Button x:Name="NavProjectsBtn"
                                       Content="프로젝트"
                                       Icon="{ui:SymbolIcon Folder24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavProjects_Click" />
                            <ui:Button x:Name="NavDevAgentBtn"
                                       Content="개발"
                                       Icon="{ui:SymbolIcon Code24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavDevAgent_Click" />
                            <ui:Button x:Name="NavPersonaBtn"
                                       Content="페르소나"
                                       Icon="{ui:SymbolIcon PeopleTeam24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavPersona_Click" />
                            <ui:Button x:Name="NavInstructionsBtn"
                                       Content="지침"
                                       Icon="{ui:SymbolIcon Document24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavInstructions_Click" />
                            <ui:Button x:Name="NavLlmBtn"
                                       Content="LLM"
                                       Icon="{ui:SymbolIcon Wand24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavLlm_Click" />
                            <ui:Button x:Name="NavApiBtn"
                                       Content="API"
                                       Icon="{ui:SymbolIcon PlugConnected24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavApiIntegration_Click" />
                            <ui:Button x:Name="NavOtherSettingsBtn"
                                       Content="기타 설정"
                                       Icon="{ui:SymbolIcon Options24}"
                                       Appearance="Transparent"
                                       Foreground="{DynamicResource PawSidebarText}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left"
                                       Margin="0,1" Padding="12,8"
                                       Click="NavOtherSettings_Click" />
                        </StackPanel>

                        <!-- User Info + Logout (bottom) -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="16,10,16,16">
                            <Border Height="1" Margin="0,0,0,10" Background="{DynamicResource PawSidebarBorder}" />
                            <TextBlock x:Name="UserDisplayName"
                                       Text="User"
                                       FontSize="13" FontWeight="SemiBold"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawSidebarHeading}" />
                            <TextBlock x:Name="UserEmail"
                                       Text="email"
                                       FontSize="11" Foreground="{DynamicResource PawSidebarMuted}"
                                       FontFamily="{StaticResource PawFont}"
                                       Margin="0,2,0,8" />
                            <Border CornerRadius="6" BorderThickness="1"
                                    BorderBrush="{DynamicResource PawGold}"
                                    Background="#22C8A96E">
                                <ui:Button x:Name="LogoutButton"
                                           Content="로그아웃"
                                           Icon="{ui:SymbolIcon SignOut24}"
                                           Appearance="Transparent"
                                           Foreground="{DynamicResource PawGold}"
                                           FontFamily="{StaticResource PawFont}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Center"
                                           Padding="10,8"
                                           Click="LogoutButton_Click" />
                            </Border>
                        </StackPanel>

                        <!-- Version -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="16,0">
                            <TextBlock x:Name="VersionLabel" FontSize="10" Foreground="{DynamicResource PawSidebarVersion}"
                                       FontFamily="{StaticResource PawFont}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- ═══ Mascot Dog ═══ -->
                        <Border DockPanel.Dock="Bottom"
                                Width="64" Height="64"
                                CornerRadius="32"
                                HorizontalAlignment="Center"
                                Margin="16,8,16,4">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#4A3F35" Offset="0" />
                                    <GradientStop Color="#3A2F28" Offset="1" />
                                </RadialGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#C8A96E" Offset="0" />
                                    <GradientStop Color="#8B7355" Offset="1" />
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>2</Border.BorderThickness>
                            <TextBlock Text="&#x1F43E;" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Spacer -->
                        <Border />
                    </DockPanel>
                </Grid>
            </Border>

            <!-- ═══════ Content Area (Parchment + Paper Grain) ═══════ -->
            <Border Grid.Column="1" Background="{DynamicResource PawDarkBg}">
                <!-- Paper grain texture overlay -->
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="0" Color="#8B7355" Direction="0" />
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Border.Style>
                <Grid>
                <!-- Paper grain noise -->
                <Border Background="{StaticResource PaperGrainBrush}" IsHitTestVisible="False" />
                    <!-- Header Bar -->
                    <Border Height="48" VerticalAlignment="Top"
                            Padding="20,0"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource PawBorder}">
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource PawCreamColor}" />
                        </Border.Background>
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F43E;" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="Agent Paw"
                                           VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           FontFamily="{StaticResource PawFont}"
                                           Foreground="{DynamicResource PawTextPrimary}" />
                            </StackPanel>

                            <!-- Status dots (semantic colors) -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Ellipse Width="7" Height="7" Margin="3,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource PawPlanningBlueColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="7" Height="7" Margin="3,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource PawGoldColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="7" Height="7" Margin="3,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource PawSystemGreenColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="7" Height="7" Margin="3,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource PawImplOrangeColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Width="7" Height="7" Margin="3,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource PawErrorRedColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </StackPanel>

                            <TextBlock DockPanel.Dock="Right" x:Name="HeaderUserName"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontFamily="{StaticResource PawFont}"
                                       Foreground="{DynamicResource PawTextSecondary}" />
                        </DockPanel>
                    </Border>

                    <!-- Page Content -->
                    <Grid Margin="0,48,0,0">
                        <pages:DashboardPage x:Name="DashboardPageControl" />
                        <pages:WorkspacePage x:Name="WorkspacePageControl" Visibility="Collapsed" />
                        <ContentControl x:Name="PersonaPageHost" Visibility="Collapsed" />
                        <ContentControl x:Name="InstructionsPageHost" Visibility="Collapsed" />
                        <ContentControl x:Name="SettingsPageHost" Visibility="Collapsed" />
                        <ContentControl x:Name="DevAgentPageHost" Visibility="Collapsed" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Title Bar -->
        <ui:TitleBar Title=""
                     Panel.ZIndex="100"
                     VerticalAlignment="Top"
                     ShowMaximize="True"
                     ShowMinimize="True"
                     ShowClose="True" />
    </Grid>
</ui:FluentWindow>
